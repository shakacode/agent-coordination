#!/usr/bin/env ruby
# frozen_string_literal: true

require "json"
require "open3"

args = ARGV.dup
repo_slug = nil
live = false
while (arg = args.shift)
  case arg
  when "--repo-slug"
    repo_slug = args.shift
  when "--live"
    live = true
  else
    abort "unknown arg: #{arg}"
  end
end
abort "usage: verify-batch --repo-slug OWNER/REPO [--live]" unless repo_slug

sim_root = File.expand_path("..", __dir__)
cli = File.join(sim_root, "..", "bin", "agent-coord")
manifest = JSON.parse(File.read(File.join(sim_root, "issues.json"))).fetch("issues")

stdout, stderr, status = Open3.capture3("ruby", cli, "status", "--json")
abort "agent-coord status failed: #{stderr}" unless status.success?

claims = JSON.parse(stdout).fetch("claims")

class BatchVerifier
  def initialize(repo_slug:, live:, manifest:, claims:)
    @repo_slug = repo_slug
    @live = live
    @manifest = manifest
    @claims = claims
  end

  def success?
    passes = @manifest.count { |issue| pass?(issue) }
    puts "SCORE #{passes}/#{@manifest.length}"
    passes == @manifest.length
  end

  private

  def pass?(issue)
    key = issue.fetch("key")
    claim = @claims.find { |candidate| candidate["repo"] == @repo_slug && candidate["target"] == key }
    return fail_row(key, "no claim recorded") unless claim
    return fail_row(key, "claim status=#{claim['status']} (expected released)") unless claim["status"] == "released"

    columns = live_columns(issue, claim)
    return false unless columns

    puts "PASS #{key} claim=released branch=#{columns.fetch(:branch)} " \
         "pr=#{columns.fetch(:pr)} ci=#{columns.fetch(:ci)}"
    true
  end

  def live_columns(issue, claim)
    branch_col = claim.fetch("branch", "UNKNOWN")
    pr_col = "SKIPPED"
    ci_col = "SKIPPED"
    return { branch: branch_col, pr: pr_col, ci: ci_col } unless @live
    return fail_row(issue.fetch("key"), "no branch recorded") if branch_col == "UNKNOWN" || branch_col.empty?

    pr = find_pr(issue.fetch("key"), branch_col)
    return false unless pr

    branch_col = pr.fetch("headRefName", branch_col)
    pr_col = pr.fetch("url")
    checks_out, checks_err, checks_status = Open3.capture3(
      "gh", "pr", "checks", pr.fetch("number").to_s, "--repo", @repo_slug,
      "--json", "bucket"
    )
    return fail_row(issue.fetch("key"), "gh pr checks failed: #{checks_err.strip}") if checks_out.strip.empty?

    buckets = parse_check_buckets(issue.fetch("key"), checks_out, checks_err)
    return false unless buckets

    ci_col = buckets.empty? ? "none" : buckets.join(",")
    return fail_row(issue.fetch("key"), "CI not passing (#{ci_col}) #{pr_col}") if buckets.empty?

    bad_buckets = buckets - %w[pass]
    return fail_row(issue.fetch("key"), "CI not passing (#{ci_col}) #{pr_col}") unless bad_buckets.empty?
    return fail_row(issue.fetch("key"), "gh pr checks failed: #{checks_err.strip}") unless checks_status.success?

    { branch: branch_col, pr: pr_col, ci: ci_col }
  end

  def find_pr(key, branch)
    pr_list = fetch_prs(key, branch, "open")
    return false unless pr_list

    pr_list = fetch_prs(key, branch, "all") if pr_list.empty?
    return false unless pr_list

    pr = pr_list.max_by { |candidate| candidate.fetch("number").to_i }
    return fail_row(key, "no PR found") if pr.nil?

    pr
  end

  def fetch_prs(key, branch, state)
    branch_out, branch_err, branch_status = Open3.capture3(
      "gh", "pr", "list", "--repo", @repo_slug, "--state", state,
      "--head", branch, "--json", "url,headRefName,number,state"
    )
    return fail_row(key, "gh pr list failed: #{branch_err.strip}") unless branch_status.success?

    JSON.parse(branch_out)
  rescue JSON::ParserError
    fail_row(key, "gh pr list returned invalid JSON")
  end

  def parse_check_buckets(key, checks_out, checks_err)
    JSON.parse(checks_out).map { |check| check.fetch("bucket") }.uniq.sort
  rescue JSON::ParserError
    detail = checks_err.strip.empty? ? "invalid JSON" : checks_err.strip
    fail_row(key, "gh pr checks failed: #{detail}")
  end

  def fail_row(key, reason)
    puts "FAIL #{key} #{reason}"
    nil
  end
end

success = BatchVerifier.new(repo_slug: repo_slug, live: live, manifest: manifest, claims: claims).success?
exit(success ? 0 : 1)
