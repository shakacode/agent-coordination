{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/shakacode/agent-coordination/blob/main/schema/state/v1/capacity-reservation/capacity-profile.schema.json",
  "title": "Agent Coordination Capacity Profile v1",
  "description": "Authoritative numeric concurrency capacity for one protocol-plane profile.",
  "x-contract-version": 1,
  "x-record-family": "capacity_profile",
  "x-logical-key": ["workspace", "capacity_profile_id"],
  "x-storage-key": {
    "template": "capacity_profiles/{workspace}/{capacity_profile_id}.json",
    "segment_encoding": "UTF-8 bytes; leave ASCII alphanumeric, underscore, and hyphen; percent-encode every other byte with uppercase hexadecimal"
  },
  "$ref": "#/$defs/capacity_profile",
  "$defs": {
    "workspace": {
      "type": "string",
      "minLength": 1,
      "default": "default"
    },
    "canonical_id": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128,
      "pattern": "^[a-z0-9](?:[a-z0-9._-]{0,126}[a-z0-9])?$"
    },
    "capacity_profile": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "schema_version",
        "workspace",
        "capacity_profile_id",
        "status",
        "max_concurrency",
        "updated_at"
      ],
      "properties": {
        "schema_version": { "const": 1 },
        "workspace": { "$ref": "#/$defs/workspace" },
        "capacity_profile_id": { "$ref": "#/$defs/canonical_id" },
        "status": { "enum": ["enabled", "disabled"] },
        "max_concurrency": {
          "type": "integer",
          "minimum": 1,
          "maximum": 1000
        },
        "updated_at": { "type": "string", "format": "date-time" }
      }
    }
  }
}
