{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/shakacode/agent-coordination/blob/main/schema/state/v1/capacity-reservation/capacity-reservation.schema.json",
  "title": "Agent Coordination Capacity Reservation v1",
  "description": "Short-lived, all-or-nothing capacity holds for stable batch lane references.",
  "x-contract-version": 1,
  "x-record-family": "capacity_reservation",
  "x-logical-key": ["workspace", "reservation_id"],
  "x-storage-key": {
    "template": "capacity_reservations/{workspace}/{reservation_id}.json",
    "segment_encoding": "UTF-8 bytes; leave ASCII alphanumeric, underscore, and hyphen; percent-encode every other byte with uppercase hexadecimal"
  },
  "x-cli-refusal": {
    "name": "RESERVATION_REFUSED",
    "exit_code": 4
  },
  "x-lane-hold-unique-key": ["lane_ref"],
  "x-batch-lane-ref-match": "producer",
  "x-aggregate-state": "derived from lane_holds; terminal lane holds never revive",
  "$ref": "#/$defs/capacity_reservation",
  "$defs": {
    "workspace": {
      "type": "string",
      "minLength": 1,
      "default": "default"
    },
    "canonical_id": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128,
      "pattern": "^[a-z0-9](?:[a-z0-9._-]{0,126}[a-z0-9])?$"
    },
    "lane_ref": {
      "type": "string",
      "minLength": 3,
      "maxLength": 256,
      "pattern": "^[A-Za-z0-9_.:-]+:[A-Za-z0-9_.-]+$"
    },
    "lane_hold": {
      "type": "object",
      "additionalProperties": false,
      "required": ["lane_ref", "state"],
      "properties": {
        "lane_ref": { "$ref": "#/$defs/lane_ref" },
        "state": { "enum": ["active", "consumed", "released", "expired"] },
        "consumed_at": { "type": "string", "format": "date-time" },
        "released_at": { "type": "string", "format": "date-time" },
        "expired_at": { "type": "string", "format": "date-time" }
      },
      "allOf": [
        {
          "if": { "properties": { "state": { "const": "consumed" } } },
          "then": { "required": ["consumed_at"] },
          "else": { "not": { "required": ["consumed_at"] } }
        },
        {
          "if": { "properties": { "state": { "const": "released" } } },
          "then": { "required": ["released_at"] },
          "else": { "not": { "required": ["released_at"] } }
        },
        {
          "if": { "properties": { "state": { "const": "expired" } } },
          "then": { "required": ["expired_at"] },
          "else": { "not": { "required": ["expired_at"] } }
        }
      ]
    },
    "capacity_reservation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "schema_version",
        "workspace",
        "reservation_id",
        "capacity_profile_id",
        "inbox_id",
        "owner_machine",
        "owner_id",
        "instance_id",
        "created_at",
        "expires_at",
        "ttl_seconds",
        "lane_holds"
      ],
      "properties": {
        "schema_version": { "const": 1 },
        "workspace": { "$ref": "#/$defs/workspace" },
        "reservation_id": { "$ref": "#/$defs/canonical_id" },
        "capacity_profile_id": { "$ref": "#/$defs/canonical_id" },
        "inbox_id": { "$ref": "#/$defs/canonical_id" },
        "batch_id": { "type": "string", "minLength": 1, "maxLength": 256 },
        "planning_attempt_id": { "type": "string", "minLength": 1, "maxLength": 256 },
        "owner_machine": { "type": "string", "minLength": 1, "maxLength": 256 },
        "owner_id": { "type": "string", "minLength": 1, "maxLength": 256 },
        "instance_id": { "type": "string", "minLength": 1, "maxLength": 256 },
        "created_at": { "type": "string", "format": "date-time" },
        "expires_at": { "type": "string", "format": "date-time" },
        "ttl_seconds": { "type": "integer", "minimum": 60, "maximum": 3600, "default": 900 },
        "lane_holds": {
          "type": "array",
          "minItems": 1,
          "maxItems": 1000,
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/lane_hold" }
        }
      },
      "oneOf": [
        { "required": ["batch_id"], "not": { "required": ["planning_attempt_id"] } },
        { "required": ["planning_attempt_id"], "not": { "required": ["batch_id"] } }
      ]
    }
  }
}
