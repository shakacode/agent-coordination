#!/usr/bin/env bash
# Usage: worker/bin/provision-token <machine-name> [--local] [--database NAME] [--rotate] scopes
# Prints a fresh token once; stores only its SHA-256 hash in D1.
set -euo pipefail

usage() {
  echo "usage: worker/bin/provision-token <machine-name> [--local] [--database NAME] [--rotate] --all-state" >&2
  echo "   or: worker/bin/provision-token <machine-name> [--local] [--database NAME] [--rotate] [--read-prefix PREFIX] [--write-prefix PREFIX]" >&2
  echo "       at least one prefix is required; prefix flags are repeatable" >&2
  exit 1
}

[ "$#" -ge 1 ] || usage

MACHINE="$1"
shift
case "$MACHINE" in
  --*) usage ;;
esac

SCOPE="--remote"
DATABASE="agent-coord"
ROTATE=0
READ_PREFIXES=()
WRITE_PREFIXES=()
READ_PREFIXES_GIVEN=0
WRITE_PREFIXES_GIVEN=0
ALL_STATE=0

if [[ ! "$MACHINE" =~ ^[A-Za-z0-9._:-]+$ ]]; then
  echo "machine name may contain only letters, numbers, dots, underscores, colons, and hyphens" >&2
  exit 1
fi

valid_prefix() {
  local prefix="$1"
  [[ "$prefix" != *..* ]] || return 1
  [[ "$prefix" != *//* ]] || return 1
  local segment='[A-Za-z0-9_.:-]+'
  local pattern="^(claims(/${segment}(/${segment}(/${segment}\\.json)?)?)?|heartbeats(/${segment}\\.json)?|batches(/${segment}\\.json)?|events(/${segment}(/${segment}\\.json)?)?)$"
  [[ "$prefix" =~ $pattern ]]
}

while [ "$#" -gt 0 ]; do
  case "$1" in
    --remote)
      SCOPE="--remote"
      shift
      ;;
    --local)
      SCOPE="--local"
      shift
      ;;
    --all-state)
      ALL_STATE=1
      shift
      ;;
    --database)
      [ "$#" -ge 2 ] || usage
      DATABASE="$2"
      shift 2
      ;;
    --rotate)
      ROTATE=1
      shift
      ;;
    --read-prefix)
      [ "$#" -ge 2 ] || usage
      [ -n "$2" ] || { echo "prefix cannot be empty; pass --all-state for all-state access" >&2; exit 1; }
      valid_prefix "$2" || { echo "invalid read prefix: $2" >&2; exit 1; }
      READ_PREFIXES_GIVEN=1
      READ_PREFIXES+=("$2")
      shift 2
      ;;
    --write-prefix)
      [ "$#" -ge 2 ] || usage
      [ -n "$2" ] || { echo "prefix cannot be empty; pass --all-state for all-state access" >&2; exit 1; }
      valid_prefix "$2" || { echo "invalid write prefix: $2" >&2; exit 1; }
      WRITE_PREFIXES_GIVEN=1
      WRITE_PREFIXES+=("$2")
      shift 2
      ;;
    *)
      usage
      ;;
  esac
done

if [[ ! "$DATABASE" =~ ^[A-Za-z0-9._-]+$ ]]; then
  echo "database name may contain only letters, numbers, dots, underscores, and hyphens" >&2
  exit 1
fi

if [ "$ALL_STATE" -eq 1 ] && { [ "$READ_PREFIXES_GIVEN" -eq 1 ] || [ "$WRITE_PREFIXES_GIVEN" -eq 1 ]; }; then
  echo "--all-state cannot be combined with --read-prefix or --write-prefix" >&2
  exit 1
elif [ "$ALL_STATE" -eq 1 ]; then
  READ_PREFIXES=("")
  WRITE_PREFIXES=("")
elif [ "$READ_PREFIXES_GIVEN" -ne 1 ] && [ "$WRITE_PREFIXES_GIVEN" -ne 1 ]; then
  echo "provide at least one --read-prefix or --write-prefix, or pass --all-state" >&2
  exit 1
fi

json_array() {
  local out="["
  local separator=""
  local prefix
  # Prefix validation disallows quotes and backslashes, so these strings are safe
  # to embed in the JSON payload and the single-quoted SQL literal below. Keep
  # valid_prefix in sync if the allowed character set ever changes.
  for prefix in "$@"; do
    out="${out}${separator}\"${prefix}\""
    separator=","
  done
  printf '%s]' "$out"
}

OPENSSL_BIN="${OPENSSL_BIN:-openssl}"
NPX_BIN="${NPX_BIN:-npx}"

TOKEN=$("$OPENSSL_BIN" rand -hex 24)
HASH=$(printf %s "$TOKEN" | "$OPENSSL_BIN" dgst -sha256 -r | cut -d' ' -f1)
if [ "${#READ_PREFIXES[@]}" -eq 0 ]; then
  READ_PREFIX_JSON=$(json_array)
else
  READ_PREFIX_JSON=$(json_array "${READ_PREFIXES[@]}")
fi
if [ "${#WRITE_PREFIXES[@]}" -eq 0 ]; then
  WRITE_PREFIX_JSON=$(json_array)
else
  WRITE_PREFIX_JSON=$(json_array "${WRITE_PREFIXES[@]}")
fi
SQL="INSERT INTO machines (machine, token_hash, read_prefixes, write_prefixes, created_at) VALUES ('${MACHINE}', '${HASH}', '${READ_PREFIX_JSON}', '${WRITE_PREFIX_JSON}', strftime('%Y-%m-%dT%H:%M:%SZ','now'))"
if [ "$ROTATE" -eq 1 ]; then
  SQL+=" ON CONFLICT(machine) DO UPDATE SET token_hash=excluded.token_hash, read_prefixes=excluded.read_prefixes, write_prefixes=excluded.write_prefixes, created_at=excluded.created_at, revoked_at=NULL"
fi

cd "$(dirname "$0")/.."
COMMAND=("$NPX_BIN" wrangler d1 execute "$DATABASE")
COMMAND+=("$SCOPE")
if [ "$SCOPE" = "--remote" ]; then
  COMMAND+=(--yes)
fi
COMMAND+=(--command "$SQL")
WRANGLER_STDERR=$(mktemp "${TMPDIR:-/tmp}/agent-coord-wrangler-stderr.XXXXXX")
trap 'rm -f "$WRANGLER_STDERR"' EXIT
if ! "${COMMAND[@]}" 2>"$WRANGLER_STDERR"; then
  cat "$WRANGLER_STDERR" >&2
  echo "wrangler d1 execute failed while provisioning ${MACHINE}; see wrangler output above" >&2
  if grep -Eqi "PRIMARY KEY|constraint failed" "$WRANGLER_STDERR"; then
    echo "If this was a duplicate machine or token constraint, delete or update the existing D1 machines row before re-provisioning" >&2
  fi
  exit 1
fi
cat "$WRANGLER_STDERR" >&2
rm -f "$WRANGLER_STDERR"
trap - EXIT

echo "machine:  ${MACHINE}"
echo "reads:    ${READ_PREFIX_JSON}"
echo "writes:   ${WRITE_PREFIX_JSON}"
echo "token:    ${TOKEN}"
echo "Set on that machine:"
echo "  export AGENT_COORD_API_URL=<worker-url>"
echo "  export AGENT_COORD_API_TOKEN=${TOKEN}"
echo "Persist those values in \${AGENT_COORD_ENV_FILE:-~/.config/agent-coord/env} with mode 600, then restart consumers."
