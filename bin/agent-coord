#!/usr/bin/env ruby
# frozen_string_literal: true

require "base64"
require "digest"
require "fileutils"
require "json"
require "net/http"
require "openssl"
require "open3"
require "optparse"
require "pathname"
require "securerandom"
require "shellwords"
require "stringio"
require "time"
require "tmpdir"
require "uri"

module AgentCoord
  VERSION = "0.1.0"
  SCHEMA_VERSION = 1
  LANE_CLOSED_SCHEMA_VERSION = 2
  DEFAULT_WORKSPACE = "default"
  TERMINAL_STATES = %w[done abandoned superseded].freeze
  DEFAULT_BACKEND = nil
  DEFAULT_REF = "state"
  DEFAULT_CLAIM_TTL = 4 * 60 * 60
  DEFAULT_HEARTBEAT_TTL = 15 * 60
  HEARTBEAT_DEAD_AFTER_TTL_MULTIPLIER = 4
  STATUS_STATE_ROOT_ENV = "AGENT_COORD_STATUS_STATE_ROOT"
  JSON_PREFIXES = %w[claims heartbeats batches].freeze
  STATE_PREFIXES = (JSON_PREFIXES + %w[events]).freeze
  STATE_PATH_PATTERN = %r{\A(?:
    claims/[A-Za-z0-9_.:-]+/[A-Za-z0-9_.:-]+/[A-Za-z0-9_.:-]+\.json |
    heartbeats/[A-Za-z0-9_.:-]+\.json |
    batches/[A-Za-z0-9_.:-]+\.json |
    events/[A-Za-z0-9_.:-]+/[A-Za-z0-9_.:-]+\.json
  )\z}x
  DEPENDENCY_DONE_STATUSES = %w[complete completed done merged ready].freeze
  STATUS_BATCH_METADATA_FIELDS = %w[
    repo objective instructions launch_prompt operator dashboard_url status updated_at registered_at completed_at
  ].freeze
  STATUS_LANE_METADATA_FIELDS = %w[
    thread_handle chat_handle host pr_url dashboard_url operator phase branch terminal closed_at closed_by
    pr_state evidence_url
  ].freeze
  STATUS_CLAIM_METADATA_FIELDS = %w[
    batch_id thread_handle chat_handle host pr_url dashboard_url operator phase generation instance_id
    release_mode handoff_to handoff_note terminal pr_state evidence_url workspace closed_by
  ].freeze
  STATUS_HEARTBEAT_METADATA_FIELDS = %w[
    batch_id branch thread_handle chat_handle host pr_url dashboard_url operator phase generation instance_id
  ].freeze
  STATUS_EVENT_METADATA_FIELDS = %w[
    event_id lane agent_id repo target branch status message thread_handle chat_handle host pr_url dashboard_url
    operator phase generation instance_id release_mode handoff_to handoff_note terminal pr_state evidence_url
    workspace closed_by
  ].freeze
  HEARTBEAT_TARGET_FIELDS = %w[repo target].freeze
  METADATA_OPTION_FIELDS = %w[
    thread_handle chat_handle host pr_url dashboard_url operator phase generation instance_id
  ].freeze
  HANDOFF_STATE_FIELDS = %w[
    release_mode handoff_to handoff_note
  ].freeze
  HANDOFF_OPTION_FIELDS = %w[
    handoff_to handoff_note
  ].freeze
  CLAIM_PRESERVED_FIELDS = (%w[batch_id branch] + STATUS_CLAIM_METADATA_FIELDS).uniq.freeze
  HEARTBEAT_PRESERVED_FIELDS = (HEARTBEAT_TARGET_FIELDS + STATUS_HEARTBEAT_METADATA_FIELDS).uniq.freeze
  EXIT_USAGE = 1
  EXIT_OPERATIONAL = 2
  EXIT_CLAIM_REFUSED = 3
  EXIT_CODES = {
    "usage" => EXIT_USAGE,
    "operational" => EXIT_OPERATIONAL,
    "claim_refused" => EXIT_CLAIM_REFUSED
  }.freeze

  class Error < StandardError
    attr_reader :exit_code

    def initialize(message, exit_code: EXIT_USAGE)
      super(message)
      @exit_code = exit_code
    end
  end

  class OperationalError < Error
    def initialize(message, exit_code: EXIT_OPERATIONAL)
      super
    end
  end

  class ClaimRefused < Error
    def initialize(message, exit_code: EXIT_CLAIM_REFUSED)
      super(message.start_with?("CLAIM_REFUSED") ? message : "CLAIM_REFUSED: #{message}", exit_code: exit_code)
    end
  end

  class PathValidationError < Error
  end

  class Conflict < OperationalError
  end

  StoredJson = Struct.new(:path, :data, :sha, keyword_init: true)
  DemoClock = Struct.new(:time) do
    def now
      time
    end
  end
  DemoResult = Struct.new(:code, :stdout, :stderr, keyword_init: true)

  class Runner # rubocop:disable Metrics/ClassLength
    def initialize(argv, stdout: $stdout, stderr: $stderr, clock: Time, backend_conflict_warnings: true)
      @argv = argv
      @stdout = stdout
      @stderr = stderr
      @clock = clock
      @backend_conflict_warnings = backend_conflict_warnings
    end

    def run # rubocop:disable Metrics/CyclomaticComplexity
      return print_help if @argv.empty? || help_request?(@argv.first)

      command = @argv.shift
      case command
      when "claim"
        claim(parse_options(command, @argv))
      when "release"
        release(parse_options(command, @argv))
      when "heartbeat"
        heartbeat(parse_options(command, @argv))
      when "register-batch"
        register_batch(parse_options(command, @argv))
      when "record-event"
        record_event(parse_options(command, @argv))
      when "status"
        render_status(parse_options(command, @argv))
      when "version"
        render_version(parse_options(command, @argv))
      when "config"
        @argv.shift if @argv.first == "show"
        render_config(parse_options(command, @argv))
      when "doctor"
        doctor(parse_options(command, @argv))
      when "bootstrap"
        bootstrap(parse_options(command, @argv))
      when "demo"
        demo(@argv)
      else
        raise Error, "unknown command: #{command}"
      end
    rescue OptionParser::ParseError => e
      raise Error, e.message
    end

    private

    def print_help
      @stdout.puts <<~HELP
        Usage: agent-coord <command> [options]

        Commands:
          claim      acquire or renew a claim lease
          release    mark a claim lease released
          heartbeat  upsert an agent heartbeat
          register-batch
                     write a batch manifest into coordination state
          record-event
                     append a lane or batch event into coordination state
          status     render full or scoped coordination state
          version    print CLI contract version
          config     print runtime defaults and exit-code contract
          doctor     verify backend access and state layout
          bootstrap  install the agent-coord command
          demo       run an isolated claim and takeover walkthrough

        Common options:
          --api-url URL              use the HTTP backend at URL
          --state-root PATH          use local files for tests or smoke checks
          --backend OWNER/REPO       explicit legacy GitHub backend repository
          --ref REF                  legacy GitHub backend branch/ref (default: #{DEFAULT_REF})
          --json                     emit JSON for supported commands
          -h, --help                 show command help
      HELP
      0
    end

    def help_request?(value)
      ["-h", "--help", "help"].include?(value)
    end

    def parse_options(command, argv)
      options = default_options

      parser = OptionParser.new do |opts|
        opts.banner = "Usage: agent-coord #{command} [options]"
        add_command_help(opts, command)

        add_backend_options(opts, options)
        add_target_options(opts, options)
        add_release_options(opts, options, command)
        add_event_options(opts, options)
        add_register_batch_options(opts, options)
        add_doctor_options(opts, options, command)
        add_bootstrap_options(opts, options)
        add_help_option(opts)
      end
      raise Error, "--deep is only valid for doctor" if command != "doctor" && deep_option_token?(argv)

      parser.parse!(argv)
      raise Error, "unexpected arguments: #{argv.join(' ')}" unless argv.empty?

      finalize_options(command, options)
    end

    def add_backend_options(opts, options)
      opts.on("--backend OWNER/REPO", "backend repository") { |value| options[:backend] = value }
      opts.on("--ref REF", "backend branch/ref") { |value| options[:ref] = value }
      opts.on("--state-root PATH", "use local files instead of GitHub API") { |value| options[:state_root] = value }
      opts.on("--api-url URL", "use the HTTP backend at URL") { |value| options[:api_url] = value }
      opts.on("--json", "emit JSON for supported commands") { options[:json] = true }
    end

    def add_target_options(opts, options)
      opts.on("--agent-id ID", "stable agent identifier") { |value| options[:agent_id] = value }
      opts.on("--repo OWNER/REPO", "target repository") { |value| options[:repo] = value }
      opts.on("--target ISSUE_OR_PR", "target issue or PR id") { |value| options[:target] = value }
      opts.on("--batch-id ID", "batch identifier") { |value| options[:batch_id] = value }
      opts.on("--branch BRANCH", "branch for the target") { |value| options[:branch] = value }
      opts.on("--thread-handle HANDLE", "worker chat thread handle") { |value| options[:thread_handle] = value }
      opts.on("--chat-handle HANDLE", "host-specific chat handle") { |value| options[:chat_handle] = value }
      opts.on("--host HOST", "host app or wrapper, e.g. codex or claude-code/conductor") do |value|
        options[:host] = value
      end
      opts.on("--pr-url URL", "pull request URL for the lane") { |value| options[:pr_url] = value }
      opts.on("--dashboard-url URL", "dashboard deep link for the lane") { |value| options[:dashboard_url] = value }
      opts.on("--operator NAME", "human operator for the lane") { |value| options[:operator] = value }
      opts.on("--phase PHASE", "lane phase") { |value| options[:phase] = value }
      opts.on("--generation GENERATION", Integer, "claim/lane generation") { |value| options[:generation] = value }
      opts.on("--instance-id ID", "agent process instance identifier") { |value| options[:instance_id] = value }
      opts.on("--ttl SECONDS", Integer, "lease/heartbeat TTL in seconds") { |value| options[:ttl] = value }
      opts.on("--status STATUS", "heartbeat or event status") do |value|
        options[:status] = value
        options[:status_given] = true
      end
      opts.on("--terminal TERMINAL", "terminal closeout: done, abandoned, or superseded") do |value|
        options[:terminal] = value
      end
      opts.on("--pr-state STATE", "final pull request state for terminal closeout") do |value|
        options[:pr_state] = value
      end
      opts.on("--evidence-url URL", "replayable closeout evidence pointer") { |value| options[:evidence_url] = value }
      opts.on("--workspace WORKSPACE", "coordination workspace (default: #{DEFAULT_WORKSPACE})") do |value|
        options[:workspace] = value
      end
    end

    def add_release_options(opts, options, command)
      return unless command == "release"

      opts.on("--handoff-to ID", "release handoff destination agent, host, or operator") do |value|
        options[:handoff_to] = value
      end
      opts.on("--handoff-note TEXT", "resume note for a release handoff") do |value|
        options[:handoff_note] = value
      end
    end

    def add_event_options(opts, options)
      opts.on("--type TYPE", "record-event only: event type") { |value| options[:type] = value }
      opts.on("--lane NAME", "record-event only: batch lane name") { |value| options[:lane] = value }
      opts.on("--message TEXT", "record-event only: event message") { |value| options[:message] = value }
    end

    def add_register_batch_options(opts, options)
      opts.on("--file PATH", "batch manifest JSON file") { |value| options[:file] = value }
    end

    def add_doctor_options(opts, options, command)
      return unless command == "doctor"

      opts.on("--deep", "doctor only: parse every JSON state record") { options[:deep] = true }
      opts.on("--doctor-prefix PREFIX", "doctor only: HTTP readable prefix probe") do |value|
        options[:doctor_prefix] = value
      end
    end

    def add_bootstrap_options(opts, options)
      opts.on("--install-dir PATH", "bootstrap install directory") { |value| options[:install_dir] = value }
      opts.on("--status-state-root PATH", "install agent-coord with a local status state root") do |value|
        options[:status_state_root] = value
      end
      opts.on("--profile PATH", "shell profile to update during bootstrap") { |value| options[:profile] = value }
      opts.on("--no-profile", "do not update shell profile during bootstrap") { options[:no_profile] = true }
    end

    def add_help_option(opts)
      opts.on("-h", "--help", "show command help") do
        @stdout.puts opts
        exit 0
      end
    end

    def finalize_options(command, options)
      validate_closeout_option_usage!(command, options)
      if backend_command?(command)
        resolve_backend_env(options)
        resolve_default_local_backend(command, options)
        warn_consumer_split_brain(command, options)
      end
      options
    end

    def validate_closeout_option_usage!(command, options)
      fields = %i[terminal pr_state evidence_url workspace]
      supplied = fields.select { |field| options.key?(field) }
      return if supplied.empty?

      if command == "release"
        missing_terminal = supplied.reject { |field| field == :terminal }
        if !missing_terminal.empty? && options[:terminal].to_s.empty?
          raise Error, "--#{missing_terminal.first.to_s.tr('_', '-')} requires --terminal"
        end

        return
      end
      return if command == "record-event" && options[:type] == "lane_closed"

      raise Error, "terminal-only options require --type lane_closed" if command == "record-event"

      raise Error, "--#{supplied.first.to_s.tr('_', '-')} is only valid with terminal closeout"
    end

    def backend_command?(command)
      %w[claim release heartbeat register-batch record-event status doctor].include?(command)
    end

    def default_options
      {
        backend: ENV.fetch("AGENT_COORD_BACKEND", DEFAULT_BACKEND),
        ref: ENV.fetch("AGENT_COORD_REF", DEFAULT_REF),
        state_root: nil,
        api_url: nil,
        status: "in_progress"
      }
    end

    def resolve_backend_env(options)
      cli_api = options[:api_url]
      env_api = ENV.fetch("AGENT_COORD_API_URL", nil)
      env_root = ENV.fetch("AGENT_COORD_STATE_ROOT", nil)
      env_api = nil if env_api == ""
      env_root = nil if env_root == ""

      if options[:state_root]
        if cli_api
          emit_backend_conflict_warning("warning: --api-url and --state-root are both set; using the local backend.")
        elsif env_api && !env_api.empty?
          emit_backend_conflict_warning(
            "warning: AGENT_COORD_API_URL and --state-root are both set; using the local backend."
          )
        end
        return
      end

      options[:api_url] ||= env_api
      if options[:api_url]
        if env_root
          api_source = cli_api ? "--api-url" : "AGENT_COORD_API_URL"
          emit_backend_conflict_warning(
            "warning: #{api_source} and AGENT_COORD_STATE_ROOT are both set; " \
            "using the HTTP backend. Pass --state-root to force local."
          )
        end
        return
      end
      options[:state_root] = env_root if env_root
    end

    def emit_backend_conflict_warning(message)
      @stderr.puts message if @backend_conflict_warnings
    end

    def warn_consumer_split_brain(command, options)
      return unless %w[status doctor].include?(command)
      return unless options[:state_root] && !options[:api_url]
      return unless ENV.fetch("AGENT_COORD_API_URL", "").empty?

      env_file = consumer_env_files.find { |path| consumer_api_url_configured?(path) }
      return unless env_file

      @stderr.puts(
        "warning: split-brain configuration: #{env_file} configures AGENT_COORD_API_URL, " \
        "but this CLI is using the local backend. Load that env file for fleet reads or remove it if local mode " \
        "is intended."
      )
    end

    def consumer_env_files
      configured = ENV.fetch("AGENT_COORD_ENV_FILE", "")
      config_home = ENV.fetch("XDG_CONFIG_HOME", "")
      if config_home.empty?
        home = ENV.fetch("HOME", "")
        config_home = File.join(home, ".config") unless home.empty?
      end
      conventional = if config_home.empty?
                       []
                     else
                       %w[env http-env.sh].map { |name| File.join(config_home, "agent-coord", name) }
                     end
      ([configured] + conventional).reject(&:empty?).uniq
    end

    def consumer_api_url_configured?(path)
      File.foreach(path).any? do |line|
        match = line.match(/^\s*(?:export\s+)?AGENT_COORD_API_URL\s*=\s*(.*?)\s*$/)
        next false unless match

        !match[1].to_s.delete_prefix('"').delete_suffix('"').delete_prefix("'").delete_suffix("'").empty?
      end
    rescue SystemCallError, ArgumentError
      false
    end

    def resolve_default_local_backend(command, options)
      return if options[:state_root] || options[:api_url] || !options[:backend].to_s.empty?

      status_command = %w[status doctor].include?(command)
      configured_status_root = ENV.fetch(STATUS_STATE_ROOT_ENV, nil)
      if status_command && !configured_status_root.to_s.empty?
        options[:state_root] = configured_status_root
        return
      end

      unless ENV.fetch("AGENT_COORD_API_TOKEN", "").empty?
        raise OperationalError,
              "AGENT_COORD_API_TOKEN is set but AGENT_COORD_API_URL is missing or empty; " \
              "set AGENT_COORD_API_URL or unset AGENT_COORD_API_TOKEN"
      end

      status_root = default_status_state_root if status_command
      if status_root
        options[:state_root] = status_root
        return
      end

      options[:state_root] = default_local_state_root
      options[:implicit_local] = true
      @stderr.puts "notice: local mode — single-machine only; state root: #{options[:state_root]}"
    end

    def add_command_help(opts, command)
      case command
      when "status"
        opts.separator ""
        opts.separator "Status scopes:"
        opts.separator "    no scope                      full audit; scans claims, heartbeats, and batches"
        opts.separator "    --repo OWNER/REPO --target N  target read; claim plus holder heartbeat only"
        opts.separator "    --batch-id ID                 batch read; batch, lane heartbeats, dependencies"
        opts.separator "Scoped JSON includes a degraded array for intentionally omitted state."
        opts.separator "Exit 2 means coordination state for that command is UNKNOWN."
        opts.separator ""
      when "doctor"
        opts.separator ""
        opts.separator "Doctor modes:"
        opts.separator "    default  lightweight auth, ref, and layout checks without reading every JSON file"
        opts.separator "    --deep   parse every claim, heartbeat, and batch JSON file"
        opts.separator "Exit 2 means coordination state is UNKNOWN until backend access is fixed."
        opts.separator ""
      when "register-batch"
        opts.separator ""
        opts.separator "Batch registration:"
        opts.separator "    --file PATH  JSON manifest with batch_id and lanes"
        opts.separator ""
      when "record-event"
        opts.separator ""
        opts.separator "Event recording:"
        opts.separator "    --batch-id ID --type TYPE  append an event under events/<batch-id>/"
        opts.separator "    --lane NAME                 attach the event to a registered lane"
        opts.separator ""
      when "release"
        opts.separator ""
        opts.separator "Handoff release:"
        opts.separator "    --handoff-to ID             intended next agent, host, or operator"
        opts.separator "    --handoff-note TEXT         resume note for the next claimant"
        opts.separator "    --terminal STATE            close as done, abandoned, or superseded"
        opts.separator "    --pr-state STATE            final pull request state"
        opts.separator ""
      end
    end

    def deep_option_token?(argv)
      # Keep this in sync with value-taking opts.on definitions in parse_options.
      value_options = %w[
        --backend --ref --state-root --api-url --agent-id --repo --target --batch-id --branch
        --thread-handle --chat-handle --host --pr-url --dashboard-url --operator --phase --generation --instance-id
        --handoff-to --handoff-note --terminal --pr-state --evidence-url --workspace
        --ttl --status --type --lane --message --file --install-dir
        --status-state-root --profile
      ]
      skip_next = false
      argv.any? do |arg|
        if skip_next
          skip_next = false
          false
        elsif value_options.include?(arg)
          skip_next = true
          false
        else
          arg == "--deep"
        end
      end
    end

    def claim(options)
      require_options(options, :agent_id, :repo, :target)
      ttl = positive_ttl(options[:ttl] || DEFAULT_CLAIM_TTL)
      now = now_utc
      expires_at = now + ttl
      path = AgentCoord.claim_path(options.fetch(:repo), options.fetch(:target))
      store = build_store(options)
      existing = store.read_json(path)

      if existing && active_claim_record?(existing.data) && existing.data["agent_id"] != options[:agent_id]
        holder_state = claim_holder_state(store, existing.data, now)
        unless takeover_allowed?(holder_state)
          raise ClaimRefused, claim_refusal_message(options, existing.data, holder_state)
        end
      end

      claim_updates = {
        "schema_version" => SCHEMA_VERSION,
        "repo" => options.fetch(:repo),
        "target" => options.fetch(:target).to_s,
        "agent_id" => options.fetch(:agent_id),
        "batch_id" => options[:batch_id],
        "branch" => options[:branch],
        "status" => "active",
        "claimed_at" => claim_timestamp(existing, options, now),
        "updated_at" => timestamp(now),
        "expires_at" => timestamp(expires_at)
      }.compact
      payload = preserved_payload(existing, claim_preserved_fields(existing, options))
                .merge(claim_updates)
                .merge(metadata_payload(options))
                .compact

      begin
        write_with_cas(store, path, payload, existing, "Claim #{options[:repo]}##{options[:target]}")
      rescue Conflict => e
        raise OperationalError, "claim write contention for #{options[:repo]}##{options[:target]}; #{e.message}"
      end
      @stdout.puts "claimed #{options[:repo]}##{options[:target]} by #{options[:agent_id]} " \
                   "until #{timestamp(expires_at)}"
      0
    ensure
      close_store(store)
    end

    def release(options)
      require_options(options, :agent_id, :repo, :target)
      validate_terminal_options!(options)
      now = now_utc
      path = AgentCoord.claim_path(options.fetch(:repo), options.fetch(:target))
      store = build_store(options)
      existing = store.read_json(path)
      raise Error, "no claim exists for #{options[:repo]}##{options[:target]}" unless existing

      holder = existing.data["agent_id"]
      if holder && holder != options[:agent_id]
        raise Error, "claim belongs to #{holder}; #{options[:agent_id]} cannot release it"
      end

      release_updates = {
        "agent_id" => holder || options[:agent_id],
        "status" => "released",
        "released_by" => options[:agent_id],
        "released_at" => timestamp(now),
        "updated_at" => timestamp(now),
        "expires_at" => timestamp(now)
      }
      payload = existing.data.merge(release_updates).merge(metadata_payload(options))
      payload = without_handoff_payload(payload)
      payload = payload.merge(handoff_payload(options)) if handoff_release?(options)
      payload["branch"] = options[:branch] if options[:branch]
      payload = terminal_release_payload(payload, options)
      validate_terminal_contract_payload!(payload) if options[:terminal]

      if options[:terminal]
        close_terminal_release(store, existing, payload, now, options)
        return 0
      end
      store.write_json(path, payload, message: "Release #{options[:repo]}##{options[:target]}", sha: existing.sha)
      record_handoff_event(store, payload, now) if handoff_release?(options)
      @stdout.puts "released #{options[:repo]}##{options[:target]} by #{options[:agent_id]}"
      0
    ensure
      close_store(store)
    end

    def render_version(options)
      payload = {
        "version" => VERSION,
        "schema_version" => SCHEMA_VERSION,
        "lane_closed_schema_version" => LANE_CLOSED_SCHEMA_VERSION,
        "default_backend" => DEFAULT_BACKEND,
        "default_ref" => DEFAULT_REF
      }
      emit_payload(payload, options) do
        @stdout.puts "agent-coord #{VERSION}"
        @stdout.puts "schema_version: #{SCHEMA_VERSION}"
        @stdout.puts "lane_closed_schema_version: #{LANE_CLOSED_SCHEMA_VERSION}"
        @stdout.puts "default_backend: #{default_backend_text}"
        @stdout.puts "default_ref: #{DEFAULT_REF}"
      end
      0
    end

    def render_config(options)
      payload = config_payload
      emit_payload(payload, options) do
        @stdout.puts "agent-coord config"
        @stdout.puts "version: #{payload.fetch('version')}"
        @stdout.puts "default_backend: #{default_backend_text}"
        @stdout.puts "default_claim_ttl_seconds: #{payload.fetch('default_claim_ttl_seconds')}"
        @stdout.puts "default_heartbeat_ttl_seconds: #{payload.fetch('default_heartbeat_ttl_seconds')}"
        @stdout.puts "heartbeat_dead_after_ttl_multiplier: #{payload.fetch('heartbeat_dead_after_ttl_multiplier')}"
        @stdout.puts "dependency_terminal_statuses: #{payload.fetch('dependency_terminal_statuses').join(',')}"
        @stdout.puts "exit_codes: #{payload.fetch('exit_codes').map { |name, code| "#{name}=#{code}" }.join(',')}"
      end
      0
    end

    def default_backend_text
      DEFAULT_BACKEND || "none"
    end

    def doctor(options)
      doctor_options = options.dup
      doctor_options[:state_root] ||= default_status_state_root unless doctor_options[:api_url]
      backend_kind = doctor_backend_kind(doctor_options)
      begin
        FileUtils.mkdir_p(doctor_options.fetch(:state_root)) if doctor_options[:implicit_local]
        store = verify_doctor_store(doctor_options, backend_kind, deep: options[:deep])
        store.verify_layout!(STATE_PREFIXES)
        section_notes, resource_checks, identity = doctor_deep_results(store, backend_kind, options)
      rescue JSON::ParserError, SystemCallError => e
        raise OperationalError, "state unreadable: #{e.message}"
      end

      payload = doctor_payload(doctor_options, backend_kind, options[:deep])
      payload["resource_checks"] = resource_checks if resource_checks
      payload["identity"] = identity if identity
      unless section_notes.empty?
        payload["degraded"] = section_notes.values.uniq
        payload["section_notes"] = section_notes
      end
      emit_payload(payload, options) do
        render_doctor_text(payload, doctor_options, section_notes)
      end
      0
    ensure
      close_store(store)
    end

    def doctor_payload(options, backend_kind, deep)
      payload = {
        "version" => VERSION,
        "backend" => backend_kind,
        "backend_repo" => options.fetch(:backend),
        "backend_url" => active_backend_url(options, backend_kind),
        "state_root" => options[:state_root],
        "deep" => !deep.nil?,
        "status" => "ok"
      }
      payload["doctor_prefix"] = doctor_read_prefix(options) if backend_kind == "http"
      payload
    end

    def doctor_deep_results(store, backend_kind, options)
      return [{}, nil, nil] unless options[:deep]
      return [check_state_readable!(store), nil, nil] unless backend_kind == "http"

      if options[:doctor_prefix]
        prefix = doctor_read_prefix(options)
        section_notes, resource_checks = check_http_custom_resource!(store, prefix, api_url: options[:api_url])
        return [section_notes, resource_checks, store.whoami]
      end
      section_notes, resource_checks = check_http_resources!(store, api_url: options[:api_url])
      [section_notes, resource_checks, store.whoami]
    end

    def render_doctor_text(payload, options, section_notes)
      @stdout.puts "agent-coord doctor"
      %w[version backend backend_repo].each { |key| @stdout.puts "#{key}: #{payload.fetch(key)}" }
      @stdout.puts "backend_url: #{options[:api_url]}" if payload.fetch("backend") == "http"
      @stdout.puts "doctor_prefix: #{payload.fetch('doctor_prefix')}" if payload["doctor_prefix"]
      @stdout.puts "state_root: #{options[:state_root] || '-'}"
      @stdout.puts "mode: #{payload.fetch('deep') ? 'deep' : 'lightweight'}"
      @stdout.puts "status: ok"
      render_doctor_http_details(payload)
      return if section_notes.empty?

      @stdout.puts "degraded"
      section_notes.values.uniq.each { |note| @stdout.puts "- #{note}" }
    end

    def render_doctor_http_details(payload)
      if payload["resource_checks"]
        @stdout.puts "resource_checks"
        payload.fetch("resource_checks").each { |prefix, status| @stdout.puts "- #{prefix}: #{status}" }
      end
      return unless payload["identity"]

      identity = payload.fetch("identity")
      @stdout.puts "machine: #{identity.fetch('machine')}"
      @stdout.puts "read_prefixes: #{format_scope_list(identity.fetch('read_prefixes'))}"
      @stdout.puts "write_prefixes: #{format_scope_list(identity.fetch('write_prefixes'))}"
    end

    def doctor_backend_kind(options)
      return "http" if options[:api_url] && !options[:state_root]
      return "local" if options[:state_root]
      return "github" unless options[:backend].to_s.empty?

      "unconfigured"
    end

    def verify_doctor_store(options, backend_kind, deep: false)
      store = nil
      case backend_kind
      when "http"
        store = build_store(options)
        store.verify_readable!(doctor_read_prefix(options)) unless deep
      when "local"
        store = LocalStore.new(options.fetch(:state_root))
        store.verify_root!
      when "github"
        check_command!("gh", "auth", "status")
        check_command!("gh", "repo", "view", options.fetch(:backend))
        store = build_store(options)
        store.verify_readable!
      else
        store = build_store(options)
      end
      store
    rescue StandardError
      close_store(store)
      raise
    end

    def doctor_read_prefix(options)
      options[:doctor_prefix] || JSON_PREFIXES.first
    end

    def check_http_resources!(store, api_url: nil)
      section_notes = {}
      checks = {}
      STATE_PREFIXES.each do |prefix|
        store.list_json(prefix)
        if filtered_status_list?(store, prefix)
          checks[prefix] = "filtered"
          section_notes[prefix] = "#{prefix} filtered by scoped token"
        else
          checks[prefix] = "ok"
        end
      rescue OperationalError => e
        if prefix == "events" && unsupported_event_listing?(e)
          checks[prefix] = "unsupported"
          section_notes[prefix] = "event state not supported by backend"
          next
        end
        if scoped_http_forbidden_listing?(e, prefix)
          checks[prefix] = "forbidden"
          section_notes[prefix] = "#{prefix} not readable by scoped token"
          next
        end
        raise doctor_auth_recovery_error(prefix, e, api_url:) if e.message.match?(/ failed: 401 /)

        raise
      end
      [section_notes, checks]
    end

    def check_http_custom_resource!(store, prefix, api_url: nil)
      if AgentCoord.state_record_path?(prefix)
        entry = store.read_json(prefix)
        return [{ prefix => "#{prefix} does not exist" }, { prefix => "missing" }] unless entry

        return [{}, { prefix => "ok" }]
      end

      store.list_json(prefix)
      return [{}, { prefix => "ok" }] unless filtered_status_list?(store, prefix)

      [{ prefix => "#{prefix} filtered by scoped token" }, { prefix => "filtered" }]
    rescue OperationalError => e
      raise doctor_auth_recovery_error(prefix, e, api_url:) if e.message.match?(/ failed: 401 /)
      if e.message.match?(/ failed: 403 forbidden\z/)
        return [{ prefix => "#{prefix} not readable by scoped token" }, { prefix => "forbidden" }]
      end
      if prefix.match?(%r{\Aevents(?:/|\z)}) && unsupported_event_listing?(e)
        return [{ prefix => "event state not supported by backend" }, { prefix => "unsupported" }]
      end

      raise
    end

    def doctor_auth_recovery_error(prefix, error, api_url: nil)
      local_flag = local_http_url?(api_url) ? "--local " : ""
      OperationalError.new(
        "doctor resource #{prefix} failed authentication (#{error.message}). Re-provision the machine token with: " \
        "worker/bin/provision-token <machine-name> #{local_flag}--database <database-name> --rotate " \
        "<original-scope-flags>; use the machine's recorded read/write scopes and do not infer them from the " \
        "resource that returned 401, " \
        "then update AGENT_COORD_API_TOKEN, restart consumers, and follow docs/runbooks/rotate-backend.md"
      )
    end

    def local_http_url?(url)
      host = URI(url.to_s).host
      HttpStore::LOOPBACK_HOSTS.include?(host)
    rescue URI::InvalidURIError
      false
    end

    def active_backend_url(options, backend_kind)
      backend_kind == "http" ? options[:api_url] : nil
    end

    def bootstrap(options)
      install_dir = File.expand_path(options[:install_dir] || File.join(Dir.home, ".local", "bin"))
      status_state_root = options[:status_state_root] && File.expand_path(options[:status_state_root])
      begin
        FileUtils.mkdir_p(install_dir)

        install_command(
          File.expand_path("agent-coord", __dir__),
          File.join(install_dir, "agent-coord"),
          status_state_root: status_state_root
        )
        legacy_alias_removed = remove_legacy_alias(File.join(install_dir, "agent_coord"))

        profile = nil
        unless options[:no_profile]
          profile = File.expand_path(options[:profile] || default_profile_path)
          ensure_profile_path(profile, install_dir)
        end
      rescue SystemCallError => e
        raise OperationalError, "bootstrap failed: #{e.message}"
      end

      @stdout.puts "installed agent-coord -> #{File.join(install_dir, 'agent-coord')}"
      @stdout.puts "removed legacy agent_coord -> #{File.join(install_dir, 'agent_coord')}" if legacy_alias_removed
      if profile
        @stdout.puts "profile updated: #{profile}"
      else
        @stdout.puts "profile update skipped"
      end
      0
    end

    def demo(argv)
      raise Error, "unexpected arguments: #{argv.join(' ')}" unless argv.empty?

      repo = "demo/example"
      target = "1"
      started_at = Time.utc(2026, 1, 1, 12, 0, 0)

      @stdout.puts "agent-coord demo"
      @stdout.puts "mode: isolated local store — no remote writes; temporary state is removed on exit"
      Dir.mktmpdir("agent-coord-demo") do |state_root|
        run_demo_claim_and_heartbeat(state_root, repo, target, started_at)
        run_demo_refusal(state_root, repo, target, started_at + 30)
        run_demo_liveness_step(state_root, repo, target, started_at + 120, "stale")
        run_demo_liveness_step(state_root, repo, target, started_at + 300, "dead")
        run_demo_takeover(state_root, repo, target, started_at + 300)
      end
      @stdout.puts
      @stdout.puts "demo complete; temporary state removed"
      0
    end

    def run_demo_claim_and_heartbeat(state_root, repo, target, now)
      claim_args = ["claim", "--agent-id", "demo-alpha", "--repo", repo, "--target", target, "--ttl", "3600"]
      heartbeat_args = [
        "heartbeat", "--agent-id", "demo-alpha", "--repo", repo, "--target", target, "--ttl", "60"
      ]
      require_demo_success!(run_demo_command(claim_args, state_root, now), "initial claim")
      require_demo_success!(run_demo_command(heartbeat_args, state_root, now), "initial heartbeat")

      @stdout.puts
      @stdout.puts "1. demo-alpha claims #{repo}##{target} and starts a 60-second heartbeat"
      @stdout.puts "   $ agent-coord #{claim_args.join(' ')}"
      @stdout.puts "   claimed #{repo}##{target} by demo-alpha"
      @stdout.puts "   $ agent-coord #{heartbeat_args.join(' ')}"
    end

    def run_demo_refusal(state_root, repo, target, now)
      args = ["claim", "--agent-id", "demo-beta", "--repo", repo, "--target", target]
      result = run_demo_command(args, state_root, now)
      unless result.code == EXIT_CLAIM_REFUSED && result.stderr.include?("held by demo-alpha; heartbeat live")
        raise OperationalError, "demo competing claim did not produce the expected live-holder refusal"
      end

      @stdout.puts
      @stdout.puts "2. demo-beta tries the same target while demo-alpha is live"
      @stdout.puts "   $ agent-coord #{args.join(' ')}"
      @stdout.puts "   #{result.stderr.strip}"
    end

    def run_demo_liveness_step(state_root, repo, target, now, expected_liveness)
      args = ["status", "--repo", repo, "--target", target, "--json"]
      result = run_demo_command(args, state_root, now)
      require_demo_success!(result, "#{expected_liveness} status")
      liveness = JSON.parse(result.stdout).fetch("heartbeats").first.fetch("liveness")
      unless liveness == expected_liveness
        raise OperationalError, "demo expected #{expected_liveness} heartbeat, got #{liveness}"
      end

      @stdout.puts
      step = { "stale" => 3, "dead" => 4 }.fetch(expected_liveness)
      @stdout.puts "#{step}. logical time advances; status reports the holder heartbeat"
      @stdout.puts "   $ agent-coord #{args.join(' ')}"
      @stdout.puts "   demo-alpha heartbeat #{liveness}"
    end

    def run_demo_takeover(state_root, repo, target, now)
      args = ["claim", "--agent-id", "demo-beta", "--repo", repo, "--target", target]
      require_demo_success!(run_demo_command(args, state_root, now), "dead-holder takeover")

      @stdout.puts
      @stdout.puts "5. demo-beta retries after the holder heartbeat is dead"
      @stdout.puts "   $ agent-coord #{args.join(' ')}"
      @stdout.puts "   takeover succeeded; holder is demo-beta"
    end

    def run_demo_command(argv, state_root, now)
      stdout = StringIO.new
      stderr = StringIO.new
      code = begin
        Runner.new(
          argv + ["--state-root", state_root],
          stdout: stdout,
          stderr: stderr,
          clock: DemoClock.new(now),
          backend_conflict_warnings: false
        ).run
      rescue Error => e
        stderr.puts e.message
        e.exit_code
      end
      DemoResult.new(code: code, stdout: stdout.string, stderr: stderr.string)
    end

    def require_demo_success!(result, step)
      return if result.code.zero?

      raise OperationalError, "demo #{step} failed: #{result.stderr.strip}"
    end

    def heartbeat(options)
      require_options(options, :agent_id)
      ttl = positive_ttl(options[:ttl] || DEFAULT_HEARTBEAT_TTL)
      now = now_utc
      path = AgentCoord.heartbeat_path(options.fetch(:agent_id))
      store = build_store(options)
      payload = {
        "schema_version" => SCHEMA_VERSION,
        "agent_id" => options.fetch(:agent_id),
        "repo" => options[:repo],
        "target" => options[:target]&.to_s,
        "batch_id" => options[:batch_id],
        "branch" => options[:branch],
        "status" => options.fetch(:status),
        "updated_at" => timestamp(now),
        "expires_at" => timestamp(now + ttl)
      }.compact

      upsert_json(store, path, message: "Heartbeat #{options[:agent_id]}") do |existing|
        preserved_payload(existing, heartbeat_preserved_fields(existing, options))
          .merge(payload)
          .merge(metadata_payload(options))
          .compact
      end
      @stdout.puts "heartbeat #{options[:agent_id]} #{timestamp(now)}"
      0
    ensure
      close_store(store)
    end

    def preserved_payload(existing, fields)
      status_metadata(existing&.data, fields)
    end

    def metadata_payload(options)
      METADATA_OPTION_FIELDS.each_with_object({}) do |field, metadata|
        option_name = field.to_sym
        metadata[field] = options[option_name] if options.key?(option_name) && !options[option_name].nil?
      end
    end

    def handoff_payload(options)
      return {} unless handoff_release?(options)

      HANDOFF_OPTION_FIELDS.each_with_object({ "release_mode" => "handoff" }) do |field, metadata|
        option_name = field.to_sym
        metadata[field] = options[option_name] if options.key?(option_name) && !options[option_name].nil?
      end
    end

    def handoff_release?(options)
      options.key?(:handoff_to) || options.key?(:handoff_note)
    end

    def without_handoff_payload(payload)
      payload.except(*HANDOFF_STATE_FIELDS)
    end

    def claim_preserved_fields(existing, options)
      return [] unless renewed_claim?(existing, options)

      CLAIM_PRESERVED_FIELDS
    end

    def renewed_claim?(existing, options)
      existing&.data.is_a?(Hash) &&
        active_claim_record?(existing.data) &&
        existing.data["agent_id"] == options[:agent_id] &&
        !claim_lane_changed?(existing, options)
    end

    def claim_timestamp(existing, options, now)
      return timestamp(now) unless renewed_claim?(existing, options)

      existing.data.fetch("claimed_at", timestamp(now))
    end

    def claim_lane_changed?(existing, options)
      changed_identity_fields(existing, options, "batch_id", "branch").any?
    end

    def heartbeat_preserved_fields(existing, options)
      changed_fields = heartbeat_changed_fields(existing, options)
      return HEARTBEAT_PRESERVED_FIELDS if changed_fields.empty?

      heartbeat_target_fields_to_preserve(changed_fields)
    end

    def heartbeat_changed_fields(existing, options)
      return {} unless existing&.data.is_a?(Hash)

      changed_fields = changed_identity_fields(existing, options, "repo", "target", "batch_id", "branch")
                       .merge(added_identity_fields(existing, options, "repo", "target", "batch_id", "branch"))
      changed_fields["target"] = nil if options.key?(:repo) && !options.key?(:target) && existing.data.key?("target")
      changed_fields
    end

    def heartbeat_target_fields_to_preserve(changed_fields)
      fields = []
      fields << "repo" unless changed_fields.key?("repo")
      fields << "target" unless changed_fields.key?("target") || changed_fields.key?("repo")
      fields
    end

    def changed_identity_fields(existing, options, *fields)
      identity_fields(options, *fields).select do |field, value|
        existing.data.key?(field) && existing.data[field] != value
      end
    end

    def added_identity_fields(existing, options, *fields)
      identity_fields(options, *fields).reject do |field, _value|
        existing.data.key?(field)
      end
    end

    def identity_fields(options, *fields)
      fields.each_with_object({}) do |field, payload|
        value = options[field.to_sym]
        value = value.to_s if field == "target" && !value.nil?
        payload[field] = value unless value.nil?
      end
    end

    def register_batch(options)
      require_options(options, :file)
      manifest = load_batch_manifest(options.fetch(:file))
      raise Error, "batch manifest must be a JSON object" unless manifest.is_a?(Hash)

      batch_id = manifest["batch_id"] || options[:batch_id]
      raise Error, "batch manifest missing batch_id" if batch_id.to_s.empty?
      if options[:batch_id] && options[:batch_id] != batch_id.to_s
        raise Error, "--batch-id does not match batch manifest batch_id"
      end

      now = now_utc
      path = AgentCoord.batch_path(batch_id)
      payload = manifest.merge(
        "schema_version" => SCHEMA_VERSION,
        "batch_id" => batch_id.to_s,
        "registered_at" => manifest["registered_at"] || timestamp(now),
        "updated_at" => timestamp(now)
      )
      validate_batch_manifest!(payload)

      store = build_store(options)
      existing = store.read_json(path)
      payload["registered_at"] = manifest["registered_at"] || existing&.data&.fetch("registered_at", nil) ||
                                 payload.fetch("registered_at")
      write_with_cas(store, path, payload, existing, "Register batch #{batch_id}")
      @stdout.puts "registered batch #{batch_id}"
      0
    rescue Conflict => e
      raise OperationalError, "batch registration write contention for #{batch_id}; #{e.message}"
    ensure
      close_store(store)
    end

    def record_event(options)
      require_options(options, :batch_id, :type)
      validate_record_event_options!(options)

      store = build_store(options)
      now = now_utc
      if options[:type] == "lane_closed"
        close_terminal_event(store, options, now, output: true)
        return 0
      end
      write_event_record(store, options, now, output: true)
      0
    ensure
      close_store(store)
    end

    def write_event_record(store, options, now, output:)
      3.times do
        event_id = build_event_id(now)
        path = AgentCoord.event_path(options.fetch(:batch_id), event_id)
        payload = event_payload(options, event_id, now)
        begin
          store.write_json(path, payload, message: "Record event #{options[:batch_id]} #{event_id}", create: true)
          @stdout.puts "recorded event #{options[:batch_id]} #{event_id}" if output
          return 0
        rescue Conflict
          next
        end
      end
      raise OperationalError, "event id collision while recording event for #{options[:batch_id]}"
    end

    def close_terminal_event(store, options, now, output:)
      event_options = canonical_terminal_event_options(store, options)
      authoritative, created = reserve_terminal_event(store, event_options, now)
      batch_changed = complete_terminal_batch(store, authoritative, now)
      if created
        @stdout.puts "recorded event #{event_options[:batch_id]} #{authoritative.fetch('event_id')}" if output
      elsif output
        @stdout.puts "lane already closed for #{event_options[:repo]}##{event_options[:target]}"
      end
      created || batch_changed
    end

    def reserve_terminal_event(store, options, now)
      event_id = stable_terminal_event_id(options.fetch(:lane))
      path = AgentCoord.event_path(options.fetch(:batch_id), event_id)
      requested = event_payload(options, event_id, now)
      store.write_json(path, requested, message: "Close lane #{options[:batch_id]} #{options[:lane]}", create: true)
      [requested, true]
    rescue Conflict
      existing = store.read_json(path)
      raise OperationalError, "terminal closeout reservation disappeared at #{path}" unless existing
      unless terminal_payload_semantics(existing.data) == terminal_payload_semantics(requested)
        raise Error, "conflicting terminal closeout for lane #{options[:lane]}; first closeout is authoritative"
      end

      [existing.data, false]
    end

    def stable_terminal_event_id(lane)
      "lane_closed-#{Digest::SHA256.hexdigest(lane)[0, 16]}"
    end

    def record_handoff_event(store, release_payload, now)
      batch_id = release_payload["batch_id"]
      return if batch_id.to_s.empty?

      event_options = handoff_event_options(release_payload, batch_id)
      write_event_record(store, event_options, now, output: false)
    rescue Error, SystemCallError => e
      @stderr.puts "warning: handoff event not recorded: #{e.message}"
    end

    def handoff_event_options(release_payload, batch_id)
      event_options = {
        batch_id: batch_id,
        type: "handoff",
        agent_id: release_payload["agent_id"],
        repo: release_payload["repo"],
        target: release_payload["target"],
        branch: release_payload["branch"],
        status: release_payload["status"],
        status_given: true,
        message: release_payload["handoff_note"]
      }
      (METADATA_OPTION_FIELDS + HANDOFF_OPTION_FIELDS).each do |field|
        value = release_payload[field]
        event_options[field.to_sym] = value unless value.nil?
      end
      event_options
    end

    def validate_record_event_options!(options)
      AgentCoord.batch_path(options.fetch(:batch_id))
      AgentCoord.validate_segment!(options.fetch(:type), "event type")
      validate_terminal_options!(options, event: true) if options[:type] == "lane_closed"
      return unless options.key?(:lane)

      lane = options[:lane].to_s
      raise Error, "--lane must not be empty" if lane.empty?
      raise Error, "event lane #{lane} cannot contain ':'" if malformed_lane_name?(lane)
    end

    def event_payload(options, event_id, now)
      payload = {
        "schema_version" => terminal_event?(options) ? LANE_CLOSED_SCHEMA_VERSION : SCHEMA_VERSION,
        "event_id" => event_id,
        "batch_id" => options.fetch(:batch_id).to_s,
        "type" => options.fetch(:type),
        "lane" => options[:lane],
        "agent_id" => options[:agent_id],
        "repo" => options[:repo],
        "target" => options[:target]&.to_s,
        "branch" => options[:branch],
        "message" => options[:message],
        "terminal" => options[:terminal],
        "pr_state" => options[:pr_state],
        "evidence_url" => options[:evidence_url],
        "workspace" => terminal_event?(options) ? options.fetch(:workspace, DEFAULT_WORKSPACE) : options[:workspace],
        "closed_by" => terminal_event?(options) ? closed_by_payload(options) : nil,
        "at" => timestamp(now)
      }
      payload["status"] = options[:status] if options[:status_given]
      payload.merge(metadata_payload(options))
             .merge(handoff_payload(options))
             .compact
    end

    def terminal_event?(options)
      options[:type] == "lane_closed"
    end

    def terminal_release_payload(payload, options)
      return payload unless options[:terminal]

      payload.merge(
        "terminal" => options[:terminal],
        "pr_state" => options[:pr_state],
        "evidence_url" => options[:evidence_url],
        "workspace" => options[:workspace]
      ).compact
    end

    def validate_terminal_options!(options, event: false)
      terminal = options[:terminal]
      if terminal && !TERMINAL_STATES.include?(terminal)
        raise Error, "--terminal must be one of: #{TERMINAL_STATES.join(', ')}"
      end

      if event
        require_options(options, :terminal, :agent_id, :repo, :target)
      elsif terminal && handoff_release?(options)
        raise Error, "--terminal cannot be combined with --handoff-to or --handoff-note"
      end
      validate_terminal_contract_payload!(options) if terminal
    end

    def validate_terminal_contract_payload!(payload)
      AgentCoord.validate_repo!(terminal_payload_value(payload, "repo"), "terminal closeout")
      validate_terminal_nonempty_field!(payload, "workspace", default: DEFAULT_WORKSPACE)
      validate_terminal_nonempty_field!(payload, "host", default: "UNKNOWN")
      %w[branch pr_state].each { |field| validate_terminal_nonempty_field!(payload, field) }
      %w[pr_url evidence_url].each { |field| validate_terminal_uri_field!(payload, field) }
    end

    def validate_terminal_nonempty_field!(payload, field, default: nil)
      value = terminal_payload_value(payload, field)
      value = default if value.nil?
      return if value.nil? || !value.to_s.empty?

      raise Error, "--#{field.tr('_', '-')} must not be empty for terminal closeout"
    end

    def validate_terminal_uri_field!(payload, field)
      value = terminal_payload_value(payload, field)
      return if value.nil?

      uri = URI.parse(value)
      return if %w[http https].include?(uri.scheme) && !uri.host.to_s.empty? && !value.match?(/\s/)

      raise Error, "--#{field.tr('_', '-')} must be an HTTP(S) URL with a host"
    rescue URI::InvalidURIError
      raise Error, "--#{field.tr('_', '-')} must be an HTTP(S) URL with a host"
    end

    def closed_by_payload(options)
      {
        "agent_id" => options[:agent_id] || options.fetch("agent_id"),
        "machine" => options[:host] || options["host"] || "UNKNOWN"
      }
    end

    def canonical_terminal_event_options(store, payload)
      batch_id = terminal_payload_value(payload, "batch_id")
      options = {
        batch_id: batch_id,
        type: "lane_closed",
        lane: terminal_payload_value(payload, "lane"),
        agent_id: terminal_payload_value(payload, "agent_id"),
        repo: terminal_payload_value(payload, "repo"),
        target: terminal_payload_value(payload, "target"),
        branch: terminal_payload_value(payload, "branch"),
        host: terminal_payload_value(payload, "host"),
        pr_url: terminal_payload_value(payload, "pr_url"),
        terminal: terminal_payload_value(payload, "terminal"),
        pr_state: terminal_payload_value(payload, "pr_state"),
        evidence_url: terminal_payload_value(payload, "evidence_url"),
        workspace: terminal_payload_value(payload, "workspace") || DEFAULT_WORKSPACE
      }.compact
      options[:lane] = lane_name(terminal_batch_lane(store, options))
      options
    end

    def close_terminal_release(store, existing, payload, now, options)
      validate_terminal_release_batch_id!(payload)
      event_options = canonical_terminal_event_options(store, payload)
      authoritative, created = reserve_terminal_event(store, event_options, now)
      reconciled_payload = authoritative_terminal_claim_payload(payload, authoritative)
      claim_changed = reconcile_terminal_claim(store, existing, reconciled_payload, options) == :changed
      batch_changed = complete_terminal_batch(store, authoritative, now)
      if created || claim_changed || batch_changed
        @stdout.puts "released #{options[:repo]}##{options[:target]} by #{options[:agent_id]}"
      else
        @stdout.puts "lane already closed for #{options[:repo]}##{options[:target]}"
      end
    end

    def authoritative_terminal_claim_payload(payload, event)
      result = payload.dup
      %w[terminal workspace closed_by pr_url pr_state evidence_url].each do |field|
        value = event[field]
        value.nil? ? result.delete(field) : result[field] = value
      end
      result
    end

    def reconcile_terminal_claim(store, existing, payload, options)
      if existing.data["status"] == "released" &&
         terminal_payload_semantics(existing.data) == terminal_payload_semantics(payload)
        return :unchanged
      end

      path = AgentCoord.claim_path(options.fetch(:repo), options.fetch(:target))
      store.write_json(path, payload, message: "Release #{options[:repo]}##{options[:target]}", sha: existing.sha)
      :changed
    rescue Conflict
      current = store.read_json(path)
      if current && current.data["status"] == "released" &&
         terminal_payload_semantics(current.data) == terminal_payload_semantics(payload)
        return :unchanged
      end

      raise
    end

    def validate_terminal_release_batch_id!(payload)
      return unless terminal_payload_value(payload, "batch_id").to_s.empty?

      raise Error, "terminal release requires a claim with batch_id"
    end

    def complete_terminal_batch(store, payload, now)
      batch_id = payload["batch_id"] || payload[:batch_id]
      batch_path = AgentCoord.batch_path(batch_id)
      3.times do
        existing = store.read_json(batch_path)
        raise Error, "batch #{batch_id} not found for terminal closeout" unless existing

        lane = terminal_batch_lane(store, payload, batch: existing.data)
        return false if terminal_lane_replay?(lane, payload)

        updated = terminal_batch_payload(store, existing.data, payload, now)
        begin
          store.write_json(batch_path, updated, message: "Close lane in batch #{batch_id}", sha: existing.sha)
          return true
        rescue Conflict
          next
        end
      end

      raise OperationalError, "batch #{batch_id} changed repeatedly during terminal closeout"
    end

    def terminal_batch_payload(store, batch, payload, now)
      updated = JSON.parse(JSON.generate(batch))
      lane = terminal_batch_lane(store, payload, batch: updated)
      terminal = payload["terminal"] || payload[:terminal]
      lane["status"] = terminal
      lane["terminal"] = terminal
      lane["closed_at"] ||= timestamp(now)
      lane["closed_by"] ||= payload["closed_by"] || closed_by_payload(payload)
      lane["workspace"] ||= terminal_payload_value(payload, "workspace") || DEFAULT_WORKSPACE
      %w[pr_url pr_state evidence_url].each do |field|
        value = payload[field] || payload[field.to_sym]
        lane[field] = value unless value.nil?
      end
      lanes = Array(updated["lanes"])
      updated["status"] = "completed" if lanes.all? { |item| TERMINAL_STATES.include?(item["terminal"]) }
      updated["completed_at"] ||= timestamp(now) if updated["status"] == "completed"
      updated["updated_at"] = timestamp(now)
      updated
    end

    def terminal_lane_replay?(lane, payload)
      return false unless lane["terminal"]
      return true if terminal_lane_semantics(lane) == terminal_payload_semantics(payload)

      raise Error, "conflicting terminal closeout for lane #{lane_name(lane)}; first closeout is authoritative"
    end

    def terminal_lane_semantics(lane)
      {
        "terminal" => lane["terminal"],
        "workspace" => lane["workspace"] || DEFAULT_WORKSPACE,
        "closed_by" => lane["closed_by"],
        "pr_url" => lane["pr_url"],
        "pr_state" => lane["pr_state"],
        "evidence_url" => lane["evidence_url"]
      }
    end

    def terminal_payload_semantics(payload)
      {
        "terminal" => terminal_payload_value(payload, "terminal"),
        "workspace" => terminal_payload_value(payload, "workspace") || DEFAULT_WORKSPACE,
        "closed_by" => terminal_payload_value(payload, "closed_by") || closed_by_payload(payload),
        "pr_url" => terminal_payload_value(payload, "pr_url"),
        "pr_state" => terminal_payload_value(payload, "pr_state"),
        "evidence_url" => terminal_payload_value(payload, "evidence_url")
      }
    end

    def terminal_batch_lane(store, payload, batch: nil)
      batch_id = terminal_payload_value(payload, "batch_id")
      batch ||= store.read_json(AgentCoord.batch_path(batch_id))&.data
      raise Error, "batch #{batch_id} not found for terminal closeout" unless batch

      validate_terminal_batch_repo!(batch, payload, batch_id)
      lane = matching_terminal_batch_lane(batch, payload, batch_id)
      validate_terminal_lane_identity!(lane, payload)
      lane
    end

    def validate_terminal_batch_repo!(batch, payload, batch_id)
      return unless batch["repo"] && batch["repo"] != terminal_payload_value(payload, "repo")

      raise Error, "terminal closeout repo does not match batch #{batch_id}"
    end

    def matching_terminal_batch_lane(batch, payload, batch_id)
      requested_lane = terminal_payload_value(payload, "lane")
      target = terminal_payload_value(payload, "target").to_s
      matches = Array(batch["lanes"]).select do |lane|
        requested_lane ? lane_name(lane) == requested_lane : terminal_lane_targets(lane).include?(target)
      end
      raise Error, "terminal closeout does not match exactly one lane in batch #{batch_id}" unless matches.one?

      matches.first
    end

    def validate_terminal_lane_identity!(lane, payload)
      target = terminal_payload_value(payload, "target").to_s
      unless terminal_lane_targets(lane).include?(target)
        raise Error, "terminal closeout target does not match lane #{lane_name(lane)}"
      end
      return if lane_owner(lane) == terminal_payload_value(payload, "agent_id")

      raise Error, "terminal closeout agent does not match lane #{lane_name(lane)}"
    end

    def terminal_lane_targets(lane)
      Array(lane["targets"] || lane["target"]).map(&:to_s)
    end

    def terminal_payload_value(payload, field)
      payload[field] || payload[field.to_sym]
    end

    def build_event_id(now)
      "#{now.utc.strftime('%Y%m%dT%H%M%S.%6NZ')}-#{SecureRandom.hex(4)}"
    end

    def render_status(options)
      status_options = options.dup
      status_options[:state_root] ||= default_status_state_root unless status_options[:api_url]
      store = build_store(status_options)
      now = now_utc
      payload =
        case status_scope(options)
        when :target
          target_status_payload(store, options, now)
        when :batch
          batch_status_payload(store, options, now)
        else
          broad_status_payload(store, now)
        end

      if options[:json]
        @stdout.puts JSON.pretty_generate(payload)
      else
        render_status_text(payload)
      end
      0
    rescue JSON::ParserError => e
      raise OperationalError, "state unreadable: #{e.message}"
    ensure
      close_store(store)
    end

    def status_scope(options)
      target_scoped = options[:repo] || options[:target]
      batch_scoped = options[:batch_id]

      raise Error, "--batch-id cannot be combined with --repo or --target" if batch_scoped && target_scoped

      if target_scoped
        require_options(options, :repo, :target)
        :target
      elsif batch_scoped
        :batch
      else
        :all
      end
    end

    def broad_status_payload(store, now)
      section_notes = {}
      grouped = JSON_PREFIXES.to_h { |prefix| [prefix, status_list_entries(store, prefix, section_notes)] }
      heartbeats_by_id = heartbeats_by_agent(grouped.fetch("heartbeats"))
      lane_states = build_lane_states(grouped.fetch("batches"), heartbeats_by_id)
      malformed_names = malformed_batch_lane_names(grouped.fetch("batches"))
      section_notes["lanes"] = "malformed lane names: #{malformed_names.join(', ')}" unless malformed_names.empty?
      event_entries = status_event_entries(store, "events", section_notes)

      status_payload(
        scope: { "kind" => "all" },
        section_notes: section_notes,
        claim_entries: grouped.fetch("claims"),
        heartbeat_entries: grouped.fetch("heartbeats"),
        batch_entries: grouped.fetch("batches"),
        event_entries: event_entries,
        heartbeats_by_agent: heartbeats_by_id,
        lane_states: lane_states,
        now: now
      )
    end

    def target_status_payload(store, options, now)
      claim = store.read_json(AgentCoord.claim_path(options.fetch(:repo), options.fetch(:target)))
      heartbeat_entries = []
      heartbeat = nil
      holder = nil
      if claim
        holder = claim.data["agent_id"].to_s
        heartbeat = read_status_heartbeat(store, holder)
        heartbeat_entries << heartbeat if valid_status_heartbeat?(heartbeat)
      end
      section_notes = {
        "batches" => "not checked in target scope",
        "events" => "not checked in target scope"
      }
      if claim && heartbeat_entries.empty?
        section_notes["heartbeats"] = if heartbeat == :invalid
                                        "holder heartbeat unreadable"
                                      elsif heartbeat == :mismatched
                                        "holder heartbeat mismatched"
                                      elsif holder.to_s.empty?
                                        "claim holder not set"
                                      else
                                        "holder heartbeat not found"
                                      end
      end

      status_payload(
        scope: {
          "kind" => "target",
          "repo" => options.fetch(:repo),
          "target" => options.fetch(:target).to_s
        },
        section_notes: section_notes,
        claim_entries: [claim].compact,
        heartbeat_entries: heartbeat_entries,
        batch_entries: [],
        event_entries: [],
        heartbeats_by_agent: heartbeats_by_agent(heartbeat_entries),
        lane_states: {},
        now: now
      )
    end

    # rubocop:disable Metrics/AbcSize, Metrics/BlockLength, Metrics/CyclomaticComplexity, Metrics/MethodLength, Metrics/PerceivedComplexity
    def batch_status_payload(store, options, now)
      heartbeat_entries_by_agent = {}
      batch_entry = store.read_json(AgentCoord.batch_path(options.fetch(:batch_id)))
      batch_entries = [batch_entry].compact
      lane_states = {}
      section_notes = { "claims" => "not checked in batch scope" }
      event_entries =
        status_event_entries(store, AgentCoord.event_batch_prefix(options.fetch(:batch_id)), section_notes)
      malformed_dependency_refs = []
      unresolved_dependency_refs = []
      malformed_lane_names = []

      if batch_entry
        batch_id = batch_entry.data.fetch("batch_id", AgentCoord.target_from_path(batch_entry.path))
        lanes = Array(batch_entry.data["lanes"])
        lanes.each do |lane|
          name = lane_name(lane)
          if malformed_lane_name?(name)
            malformed_lane_names << name
            next
          end

          heartbeat = read_cached_status_heartbeat(store, lane_owner(lane), heartbeat_entries_by_agent)
          lane_states["#{batch_id}:#{name}"] = lane_status(lane, status_heartbeat_data(heartbeat))
        end

        dependency_refs = lanes.flat_map { |lane| lane_dependencies(lane) }.uniq
        dependency_refs.each do |dependency|
          next if lane_states.key?(dependency)

          candidates = dependency_lane_ref_candidates(dependency)
          if candidates.empty?
            malformed_dependency_refs << dependency
            next
          end

          malformed_dependency_ref = false
          candidates.each do |dependency_batch_id, dependency_lane_name|
            dependency_batch_path = batch_path_for_status(dependency_batch_id)
            malformed_dependency_ref = true unless dependency_batch_path
            next unless dependency_batch_path

            dependency_batch = store.read_json(dependency_batch_path)
            next unless dependency_batch

            dependency_lane = Array(dependency_batch.data["lanes"]).find do |lane|
              name = lane_name(lane)
              !malformed_lane_name?(name) && name == dependency_lane_name
            end
            unless dependency_lane
              malformed_dependency_ref = true
              next
            end

            heartbeat = read_cached_status_heartbeat(store, lane_owner(dependency_lane), heartbeat_entries_by_agent)
            lane_states[dependency] = lane_status(dependency_lane, status_heartbeat_data(heartbeat))
            break
          end
          malformed_dependency_refs << dependency if malformed_dependency_ref && !lane_states.key?(dependency)
          unresolved_dependency_refs << dependency if !malformed_dependency_ref && !lane_states.key?(dependency)
        end

        heartbeat_notes = []
        unreadable_heartbeat_owners = heartbeat_entries_by_agent.select { |_, entry| entry == :invalid }.keys
        mismatched_heartbeat_owners = heartbeat_entries_by_agent.select { |_, entry| entry == :mismatched }.keys
        missing_heartbeat_owners = heartbeat_entries_by_agent.select { |_, entry| entry.nil? }.keys
        unless unreadable_heartbeat_owners.empty?
          heartbeat_notes << "lane-owner heartbeats unreadable: #{unreadable_heartbeat_owners.join(', ')}"
        end
        unless mismatched_heartbeat_owners.empty?
          heartbeat_notes << "lane-owner heartbeats mismatched: #{mismatched_heartbeat_owners.join(', ')}"
        end
        unless missing_heartbeat_owners.empty?
          heartbeat_notes << "lane-owner heartbeats not found: #{missing_heartbeat_owners.join(', ')}"
        end
        section_notes["heartbeats"] = heartbeat_notes.join("; ") unless heartbeat_notes.empty?
        unless malformed_lane_names.empty?
          section_notes["lanes"] =
            "malformed lane names: #{malformed_lane_names.join(', ')}"
        end
        unless malformed_dependency_refs.empty?
          section_notes["dependencies"] =
            "malformed dependency refs: #{malformed_dependency_refs.join(', ')}"
        end
        unless unresolved_dependency_refs.empty?
          section_notes["unresolved_dependencies"] =
            "unresolved dependency refs: #{unresolved_dependency_refs.join(', ')}"
        end
      else
        section_notes["batches"] = "batch not found"
      end

      status_payload(
        scope: { "kind" => "batch", "batch_id" => options.fetch(:batch_id).to_s },
        section_notes: section_notes,
        claim_entries: [],
        heartbeat_entries: heartbeat_entries_by_agent.values.select { |entry| valid_status_heartbeat?(entry) },
        batch_entries: batch_entries,
        event_entries: event_entries,
        heartbeats_by_agent: heartbeat_entries_by_agent,
        lane_states: lane_states,
        now: now
      )
    end
    # rubocop:enable Metrics/AbcSize, Metrics/BlockLength, Metrics/CyclomaticComplexity, Metrics/MethodLength, Metrics/PerceivedComplexity

    # rubocop:disable Metrics/ParameterLists
    def status_payload(scope:, section_notes:, claim_entries:, heartbeat_entries:, batch_entries:,
                       event_entries:, heartbeats_by_agent:, lane_states:, now:)
      {
        "version" => VERSION,
        "scope" => scope,
        "degraded" => section_notes.values.uniq,
        "section_notes" => section_notes,
        "claims" => claim_entries.map { |entry| claim_status_hash(entry) },
        "heartbeats" => heartbeat_entries.map { |entry| heartbeat_status_hash(entry, now) },
        "batches" => batch_entries.map { |entry| batch_status_hash(entry, heartbeats_by_agent, lane_states, now) },
        "events" => event_entries.map { |entry| event_status_hash(entry) }
      }
    end
    # rubocop:enable Metrics/ParameterLists

    def render_status_text(payload)
      @stdout.puts "claims"
      if payload.fetch("claims").empty?
        @stdout.puts "- #{status_section_note(payload, 'claims') || 'none'}"
      else
        payload.fetch("claims").each do |claim|
          @stdout.puts [
            "- #{claim.fetch('repo')}##{claim.fetch('target')}",
            claim.fetch("status"),
            claim.fetch("agent_id"),
            "branch #{claim.fetch('branch')}",
            "expires #{claim.fetch('expires_at')}"
          ].join(" ")
        end
      end

      @stdout.puts "heartbeats"
      if payload.fetch("heartbeats").empty?
        @stdout.puts "- #{status_section_note(payload, 'heartbeats') || 'none'}"
      else
        payload.fetch("heartbeats").each do |heartbeat|
          @stdout.puts "- #{heartbeat.fetch('agent_id')} " \
                       "#{heartbeat.fetch('status')} " \
                       "#{heartbeat.fetch('liveness')} " \
                       "#{heartbeat.fetch('target')} updated #{heartbeat.fetch('updated_at')}"
        end
      end

      @stdout.puts "batches"
      if payload.fetch("batches").empty?
        @stdout.puts "- #{status_section_note(payload, 'batches') || 'none'}"
      else
        payload.fetch("batches").each do |batch|
          render_batch_status_hash(batch)
        end
      end

      render_status_events(payload)

      degraded = payload.fetch("degraded", [])
      return if degraded.empty?

      @stdout.puts "degraded"
      degraded.each { |note| @stdout.puts "- #{note}" }
    end

    def status_section_note(payload, section)
      payload.dig("section_notes", section)
    end

    def claim_status_hash(entry)
      data = entry.data
      {
        "path" => entry.path,
        "repo" => data.fetch("repo", AgentCoord.repo_from_claim_path(entry.path)),
        "target" => data.fetch("target", AgentCoord.target_from_path(entry.path)),
        "status" => data.fetch("status", "unknown"),
        "agent_id" => data.fetch("agent_id", "UNKNOWN"),
        "branch" => data.fetch("branch", "UNKNOWN"),
        "expires_at" => data.fetch("expires_at", "UNKNOWN")
      }.merge(status_metadata(data, STATUS_CLAIM_METADATA_FIELDS))
    end

    def heartbeat_status_hash(entry, now)
      data = entry.data
      target = [data["repo"], data["target"]].compact.join("#")
      target = "-" if target.empty?
      {
        "path" => entry.path,
        "agent_id" => data.fetch("agent_id", AgentCoord.target_from_path(entry.path)),
        "status" => data.fetch("status", "unknown"),
        "liveness" => heartbeat_liveness(data, now),
        "target" => target,
        "updated_at" => data.fetch("updated_at", "UNKNOWN")
      }.merge(status_metadata(data, STATUS_HEARTBEAT_METADATA_FIELDS))
    end

    def batch_status_hash(entry, heartbeats_by_agent, lane_states, now)
      batch = entry.data
      batch_id = batch.fetch("batch_id", AgentCoord.target_from_path(entry.path))
      lanes = Array(batch["lanes"]).map do |lane|
        name = lane_name(lane)
        owner = lane_owner(lane)
        heartbeat = heartbeats_by_agent[owner]
        heartbeat_data = status_heartbeat_data(heartbeat)
        status = lane_status(lane, heartbeat_data)
        liveness = status_heartbeat_liveness(heartbeat, now)
        deps = lane_dependencies(lane)
        blocked_on = deps.reject { |dependency| dependency_met?(dependency, lane_states) }

        {
          "name" => name,
          "owner" => owner,
          "targets" => Array(lane["targets"] || lane["target"]).compact.map(&:to_s),
          "status" => status,
          "liveness" => liveness,
          "deps" => deps,
          "blocked_on" => blocked_on
        }.merge(status_metadata(lane, STATUS_LANE_METADATA_FIELDS))
      end

      {
        "path" => entry.path,
        "batch_id" => batch_id,
        "lanes" => lanes
      }.merge(status_metadata(batch, STATUS_BATCH_METADATA_FIELDS))
    end

    def event_status_hash(entry)
      data = entry.data
      {
        "path" => entry.path,
        "batch_id" => data.fetch("batch_id", AgentCoord.event_batch_from_path(entry.path)),
        "type" => data.fetch("type", "unknown"),
        "at" => data.fetch("at", "UNKNOWN")
      }.merge(status_metadata(data, STATUS_EVENT_METADATA_FIELDS))
    end

    def status_metadata(data, fields)
      return {} unless data.is_a?(Hash)

      fields.each_with_object({}) do |field, metadata|
        metadata[field] = data[field] if data.key?(field) && !data[field].nil?
      end
    end

    def render_batch_status_hash(batch)
      @stdout.puts "- #{batch.fetch('batch_id')}"
      if batch.fetch("lanes").empty?
        @stdout.puts "  - lanes -"
        return
      end

      batch.fetch("lanes").each do |lane|
        @stdout.puts "  - lane #{lane.fetch('name')} owner #{lane.fetch('owner')} " \
                     "targets #{format_list(lane.fetch('targets'))} " \
                     "status #{lane.fetch('status')} #{lane.fetch('liveness')} " \
                     "deps #{format_list(lane.fetch('deps'))} blocked_on #{format_list(lane.fetch('blocked_on'))}"
      end
    end

    def render_event_status_hash(event)
      details = [
        "- #{event.fetch('batch_id')}",
        event.fetch("lane", "-"),
        event.fetch("type"),
        event.fetch("phase", event.fetch("status", "-")),
        "by #{event.fetch('agent_id', '-')}",
        "at #{event.fetch('at')}"
      ]
      message = event["message"].to_s
      details << message unless message.empty?
      @stdout.puts details.join(" ")
    end

    def render_status_events(payload)
      @stdout.puts "events"
      if payload.fetch("events").empty?
        @stdout.puts "- #{status_section_note(payload, 'events') || 'none'}"
      else
        payload.fetch("events").each do |event|
          render_event_status_hash(event)
        end
      end
    end

    def status_list_entries(store, prefix, section_notes)
      entries = store.list_json(prefix)
      section_notes[prefix] = "#{prefix} filtered by scoped token" if filtered_status_list?(store, prefix)
      entries
    rescue OperationalError => e
      raise unless scoped_http_forbidden_listing?(e, prefix)

      section_notes[prefix] = "#{prefix} not readable by scoped token"
      []
    end

    def status_event_entries(store, prefix, section_notes)
      entries = store.list_json(prefix).sort_by { |entry| [entry.data["at"].to_s, entry.path] }
      section_notes["events"] = "events filtered by scoped token" if filtered_status_list?(store, prefix)
      entries
    rescue OperationalError => e
      raise unless unsupported_event_listing?(e) || scoped_http_forbidden_listing?(e, prefix)

      section_notes["events"] =
        if scoped_http_forbidden_listing?(e, prefix)
          "events not readable by scoped token"
        else
          "event state not supported by backend"
        end
      []
    end

    def filtered_status_list?(store, prefix)
      store.respond_to?(:filtered_list?) && store.filtered_list?(prefix)
    end

    def scoped_http_forbidden_listing?(error, prefix)
      error.message.match?(/\Ahttp backend list #{Regexp.escape(prefix)} failed: 403 forbidden\z/)
    end

    def unsupported_event_listing?(error)
      # Broadly detects pre-events backends until the protocol has a version handshake.
      error.message.match?(/invalid_(prefix|path)|route_not_found/)
    end

    def read_status_heartbeat(store, agent_id)
      return nil if agent_id.to_s.empty? || agent_id == "UNKNOWN"

      path = AgentCoord.heartbeat_path(agent_id)
      entry = store.read_json(path)
      return nil unless entry

      payload_agent_id = entry.data.fetch("agent_id", AgentCoord.target_from_path(entry.path)).to_s
      return :mismatched unless payload_agent_id == agent_id

      entry
    rescue JSON::ParserError
      :invalid
    rescue PathValidationError
      nil
    end

    def read_cached_status_heartbeat(store, agent_id, cache)
      if agent_id.to_s.empty? || agent_id == "UNKNOWN"
        cache[agent_id] = nil unless agent_id.to_s.empty?
        return nil
      end
      return cache[agent_id] if cache.key?(agent_id)

      cache[agent_id] = read_status_heartbeat(store, agent_id)
    end

    def valid_status_heartbeat?(entry)
      entry && !%i[invalid mismatched].include?(entry)
    end

    def status_heartbeat_data(entry)
      return entry if entry.is_a?(Hash)

      valid_status_heartbeat?(entry) ? entry.data : nil
    end

    def status_heartbeat_liveness(entry, now)
      case entry
      when :invalid
        "unreadable"
      when :mismatched
        "mismatched"
      when Hash
        heartbeat_liveness(entry, now)
      else
        valid_status_heartbeat?(entry) ? heartbeat_liveness(entry.data, now) : "no-heartbeat"
      end
    end

    def dependency_lane_ref_candidates(ref)
      value = ref.to_s
      separator = value.rindex(":")
      return [] unless separator

      batch_id = value[0...separator]
      lane = value[(separator + 1)..]
      return [] if batch_id.to_s.empty? || lane.to_s.empty?

      [[batch_id, lane]]
    end

    def batch_path_for_status(batch_id)
      AgentCoord.batch_path(batch_id)
    rescue PathValidationError
      nil
    end

    def heartbeats_by_agent(entries)
      entries.to_h do |entry|
        data = entry.data
        [data.fetch("agent_id", AgentCoord.target_from_path(entry.path)), data]
      end
    end

    def build_lane_states(batches, heartbeats_by_agent)
      batches.each_with_object({}) do |entry, states|
        batch = entry.data
        batch_id = batch.fetch("batch_id", AgentCoord.target_from_path(entry.path))
        Array(batch["lanes"]).each do |lane|
          name = lane_name(lane)
          next if malformed_lane_name?(name)

          owner = lane_owner(lane)
          heartbeat = heartbeats_by_agent[owner]
          states["#{batch_id}:#{name}"] = lane_status(lane, heartbeat)
        end
      end
    end

    def malformed_batch_lane_names(batches)
      batches.flat_map do |entry|
        Array(entry.data["lanes"]).filter_map do |lane|
          name = lane_name(lane)
          name if malformed_lane_name?(name)
        end
      end
    end

    def lane_name(lane)
      lane["name"] || lane["id"] || "UNKNOWN"
    end

    def malformed_lane_name?(name)
      name.to_s.include?(":")
    end

    def lane_owner(lane)
      owner = lane["owner"] || lane["agent_id"]
      owner.to_s.empty? ? "UNKNOWN" : owner
    end

    def lane_status(lane, heartbeat)
      lane["terminal"] || heartbeat&.fetch("status", nil) || lane["status"] || "unknown"
    end

    def lane_dependencies(lane)
      Array(lane["depends_on"]).compact.map(&:to_s)
    end

    def dependency_met?(dependency, lane_states)
      DEPENDENCY_DONE_STATUSES.include?(lane_states.fetch(dependency, nil).to_s)
    end

    def format_list(values)
      compact_values = Array(values).compact.map(&:to_s).reject(&:empty?)
      compact_values.empty? ? "-" : compact_values.join(",")
    end

    def format_scope_list(values)
      values.include?("") ? "all-state" : format_list(values)
    end

    def build_store(options)
      return LocalStore.new(options.fetch(:state_root)) if options[:state_root]

      if options[:api_url]
        token = ENV.fetch("AGENT_COORD_API_TOKEN", nil)
        raise OperationalError, "AGENT_COORD_API_TOKEN is required when using the HTTP backend" if token.to_s.empty?

        return HttpStore.new(base_url: options[:api_url], token: token)
      end

      raise OperationalError, missing_backend_message if options[:backend].to_s.empty?

      GitHubStore.new(backend: options.fetch(:backend), ref: options.fetch(:ref))
    end

    def close_store(store)
      store.close if store.respond_to?(:close)
    end

    def missing_backend_message
      "no coordination backend configured; set AGENT_COORD_API_URL and AGENT_COORD_API_TOKEN " \
        "for the HTTP backend, set AGENT_COORD_STATE_ROOT for local state, or pass --backend " \
        "or AGENT_COORD_BACKEND to explicitly use the legacy GitHub backend"
    end

    def default_status_state_root
      configured_root = ENV.fetch(STATUS_STATE_ROOT_ENV, nil)
      return configured_root unless configured_root.to_s.empty?

      source_root = AgentCoord.source_root
      AgentCoord.state_root?(source_root) ? source_root : nil
    end

    def default_local_state_root
      state_home = ENV.fetch("XDG_STATE_HOME", nil)
      state_home = nil unless Pathname.new(state_home.to_s).absolute?
      return File.join(File.expand_path(state_home), "agent-coordination") if state_home

      home = home_directory
      raise OperationalError, local_state_home_error unless Pathname.new(home.to_s).absolute?

      File.join(File.expand_path(home), ".local", "state", "agent-coordination")
    rescue ArgumentError
      raise OperationalError, local_state_home_error
    end

    def home_directory
      Dir.home
    end

    def local_state_home_error
      "cannot determine local state root; set XDG_STATE_HOME or HOME to an absolute path, or pass --state-root"
    end

    def write_with_cas(store, path, payload, existing, message)
      if existing
        store.write_json(path, payload, message: message, sha: existing.sha)
      else
        store.write_json(path, payload, message: message, create: true)
      end
    end

    def upsert_json(store, path, message:)
      2.times do
        existing = store.read_json(path)
        next_payload = yield(existing)
        store.write_json(path, next_payload, message: message, sha: existing&.sha, create: existing.nil?)
        return
      rescue Conflict
        next
      end
      raise Conflict, "state changed while writing #{path}"
    end

    def active_claim_record?(claim)
      claim["status"] == "active"
    end

    def claim_holder_state(store, claim, now)
      holder = claim["agent_id"].to_s
      heartbeat = holder.empty? ? nil : read_holder_heartbeat(store, holder)
      return fallback_holder_state(claim, now, "invalid") if heartbeat == :invalid

      liveness = heartbeat && heartbeat_liveness(heartbeat.data, now)

      return { liveness: liveness } if %w[live stale dead].include?(liveness)

      fallback_holder_state(claim, now, heartbeat ? "unknown" : "missing")
    end

    def fallback_holder_state(claim, now, liveness)
      {
        liveness: liveness,
        fallback_live: claim_fallback_live?(claim, now),
        fallback_expires_at: claim["expires_at"]
      }
    end

    def read_holder_heartbeat(store, holder)
      store.read_json(AgentCoord.heartbeat_path(holder))
    rescue OperationalError
      raise
    rescue JSON::ParserError
      :invalid
    rescue Error
      nil
    end

    def takeover_allowed?(holder_state)
      return false if %w[live stale].include?(holder_state.fetch(:liveness))
      return true if holder_state.fetch(:liveness) == "dead"

      !holder_state.fetch(:fallback_live)
    end

    def claim_refusal_message(options, claim, holder_state)
      holder = claim.fetch("agent_id", "UNKNOWN")
      liveness = holder_state.fetch(:liveness)
      details =
        if %w[live stale].include?(liveness)
          "heartbeat #{liveness}"
        else
          "heartbeat #{liveness}; fallback claim expires at #{holder_state.fetch(:fallback_expires_at, 'UNKNOWN')}"
        end
      "active claim for #{options[:repo]}##{options[:target]} held by #{holder}; #{details}"
    end

    def claim_fallback_live?(claim, now)
      parse_time(claim["expires_at"]) > now
    rescue ArgumentError, TypeError
      false
    end

    def heartbeat_liveness(heartbeat, now)
      updated_at = parse_time(heartbeat.fetch("updated_at"))
      expires_at = parse_time(heartbeat.fetch("expires_at"))
      ttl = expires_at - updated_at
      return "dead" unless ttl.positive?
      return "live" if now < expires_at
      return "stale" if now < updated_at + (HEARTBEAT_DEAD_AFTER_TTL_MULTIPLIER * ttl)

      "dead"
    rescue ArgumentError, KeyError, TypeError
      "unknown"
    end

    def load_batch_manifest(path)
      JSON.parse(File.read(path))
    rescue JSON::ParserError => e
      raise Error, "batch manifest JSON invalid: #{e.message}"
    rescue SystemCallError => e
      raise OperationalError, "batch manifest unreadable: #{e.message}"
    end

    def validate_batch_manifest!(manifest)
      raise Error, "batch manifest must be a JSON object" unless manifest.is_a?(Hash)

      batch_id = manifest["batch_id"].to_s
      raise Error, "batch manifest missing batch_id" if batch_id.empty?

      AgentCoord.batch_path(batch_id)
      AgentCoord.validate_repo!(manifest["repo"], "batch") if manifest["repo"]
      lanes = manifest["lanes"]
      raise Error, "batch manifest lanes must be an array" unless lanes.is_a?(Array)
      raise Error, "batch manifest lanes must not be empty" if lanes.empty?

      seen_names = {}
      lanes.each_with_index do |lane, index|
        name = validate_batch_lane!(lane, index + 1)
        raise Error, "batch lane #{name} is duplicated" if seen_names[name]

        seen_names[name] = true
      end
    end

    def validate_batch_lane!(lane, position)
      raise Error, "batch lane #{position} must be a JSON object" unless lane.is_a?(Hash)

      name = batch_lane_name_for_validation(lane, position)
      raise Error, "batch lane #{name} cannot contain ':'" if malformed_lane_name?(name)

      owner = batch_lane_owner_for_validation(lane, name)
      AgentCoord.validate_segment!(owner, "lane owner")
      targets = Array(lane["targets"] || lane["target"]).compact.map(&:to_s).reject(&:empty?)
      raise Error, "batch lane #{name} missing targets" if targets.empty?

      targets.each { |target| AgentCoord.validate_segment!(target, "lane target") }
      lane_dependencies(lane).each do |dependency|
        next if dependency_lane_ref_candidates(dependency).any? do |dependency_batch_id, dependency_lane_name|
          batch_path_for_status(dependency_batch_id) && !dependency_lane_name.to_s.empty?
        end

        raise Error, "batch lane #{name} has invalid dependency ref: #{dependency}"
      end
      name
    end

    def batch_lane_name_for_validation(lane, position)
      name = lane.key?("name") ? lane["name"] : lane["id"]
      raise Error, "batch lane #{position} missing name" if name.nil?
      raise Error, "batch lane #{position} name must be a string" unless name.is_a?(String)
      raise Error, "batch lane #{position} missing name" if name.empty?

      name
    end

    def batch_lane_owner_for_validation(lane, name)
      owner = lane.key?("owner") ? lane["owner"] : lane["agent_id"]
      raise Error, "batch lane #{name} missing owner" if owner.nil?
      raise Error, "batch lane #{name} owner must be a string" unless owner.is_a?(String)
      raise Error, "batch lane #{name} missing owner" if owner.empty?

      owner
    end

    def require_options(options, *names)
      names.each do |name|
        raise Error, "missing required --#{name.to_s.tr('_', '-')}" if options[name].to_s.empty?
      end
    end

    def positive_ttl(ttl)
      raise Error, "--ttl must be positive" unless ttl.to_i.positive?

      ttl.to_i
    end

    def now_utc
      @clock.now.utc
    end

    def timestamp(time)
      time.utc.iso8601
    end

    def parse_time(value)
      Time.iso8601(value).utc
    end

    def config_payload
      {
        "version" => VERSION,
        "schema_version" => SCHEMA_VERSION,
        "lane_closed_schema_version" => LANE_CLOSED_SCHEMA_VERSION,
        "default_backend" => DEFAULT_BACKEND,
        "default_ref" => DEFAULT_REF,
        "default_claim_ttl_seconds" => DEFAULT_CLAIM_TTL,
        "default_heartbeat_ttl_seconds" => DEFAULT_HEARTBEAT_TTL,
        "heartbeat_dead_after_ttl_multiplier" => HEARTBEAT_DEAD_AFTER_TTL_MULTIPLIER,
        "dependency_terminal_statuses" => DEPENDENCY_DONE_STATUSES,
        "exit_codes" => EXIT_CODES
      }
    end

    def emit_payload(payload, options)
      if options[:json]
        @stdout.puts JSON.pretty_generate(payload)
      else
        yield
      end
    end

    def check_command!(*args)
      stdout, stderr, status = Open3.capture3(*args)
      return if status.success?

      message = [stderr, stdout].reject(&:empty?).join("\n")
      raise OperationalError, "#{args.join(' ')} failed: #{message}"
    rescue SystemCallError => e
      raise OperationalError, "#{args.join(' ')} failed: #{e.message}"
    end

    def check_state_readable!(store)
      section_notes = {}
      STATE_PREFIXES.each do |prefix|
        store.list_json(prefix)
        section_notes[prefix] = "#{prefix} filtered by scoped token" if filtered_status_list?(store, prefix)
      rescue OperationalError => e
        raise unless scoped_http_forbidden_listing?(e, prefix)

        section_notes[prefix] = "#{prefix} not readable by scoped token"
      end
      section_notes
    end

    def install_link(source, destination)
      raise OperationalError, "bootstrap source missing: #{source}" unless File.exist?(source)

      FileUtils.ln_sf(source, destination)
    end

    def install_command(source, destination, status_state_root:)
      return install_link(source, destination) unless status_state_root

      install_wrapper(source, destination, status_state_root)
    end

    def install_wrapper(source, destination, status_state_root)
      raise OperationalError, "bootstrap source missing: #{source}" unless File.exist?(source)

      FileUtils.rm_f(destination)
      File.write(
        destination,
        <<~SH
          #!/bin/sh
          export #{STATUS_STATE_ROOT_ENV}=#{Shellwords.escape(status_state_root)}
          exec #{Shellwords.escape(source)} "$@"
        SH
      )
      FileUtils.chmod(0o755, destination)
    end

    def remove_legacy_alias(destination)
      return false unless File.symlink?(destination) || File.exist?(destination)

      legacy_source = File.expand_path("agent_coord", __dir__)
      if File.symlink?(destination)
        link_target = File.readlink(destination)
        link_target = File.expand_path(link_target, File.dirname(destination)) unless link_target.start_with?("/")
        return false unless link_target == legacy_source

        FileUtils.rm_f(destination)
        return true
      end

      return false unless File.file?(destination)

      content = File.binread(destination, 16 * 1024)
      escaped_legacy_source = Shellwords.escape(legacy_source)
      return false unless content.start_with?("#!/bin/sh".b) &&
                          (content.include?(legacy_source.b) || content.include?(escaped_legacy_source.b))

      FileUtils.rm_f(destination)
      true
    rescue SystemCallError
      false
    end

    def default_profile_path
      shell = File.basename(ENV.fetch("SHELL", ""))
      shell == "zsh" ? File.join(Dir.home, ".zshrc") : File.join(Dir.home, ".bashrc")
    end

    def ensure_profile_path(profile, install_dir)
      FileUtils.mkdir_p(File.dirname(profile))
      line = "export PATH=#{Shellwords.escape(install_dir)}:\"$PATH\""
      existing = File.exist?(profile) ? File.read(profile) : ""
      return if existing.lines.any? { |existing_line| existing_line.strip == line }

      File.open(profile, "a") do |file|
        file.puts
        file.puts "# agent-coord bootstrap"
        file.puts line
      end
    end
  end

  class LocalStore
    def initialize(root)
      @root = File.expand_path(root)
    end

    def verify_root!
      raise OperationalError, "state root does not exist: #{@root}" unless File.exist?(@root)
      raise OperationalError, "state root is not a directory: #{@root}" unless Dir.exist?(@root)
      raise OperationalError, "state root is not writable: #{@root}" unless File.writable?(@root)
    end

    def read_json(path)
      file = expanded_path(path)
      return nil unless File.file?(file)

      StoredJson.new(path: path, data: JSON.parse(File.read(file)), sha: file_sha(file))
    end

    # LocalStore keeps GitHubStore's keyword interface; only GitHubStore uses message.
    def write_json(path, data, message:, sha: nil, create: false) # rubocop:disable Lint/UnusedMethodArgument
      file = expanded_path(path)
      FileUtils.mkdir_p(File.dirname(file))
      with_file_lock(file) do
        raise Conflict, "state already exists at #{path}" if create && File.exist?(file)
        raise Conflict, "state changed at #{path}" if sha && (!File.exist?(file) || file_sha(file) != sha)

        File.write(file, "#{JSON.pretty_generate(data)}\n")
      end
    end

    def list_json(prefix)
      directory = expanded_path(prefix)
      return [] unless Dir.exist?(directory)

      Dir.glob(File.join(directory, "**", "*.json"), sort: true).map do |file|
        path = file.delete_prefix("#{@root}/")
        StoredJson.new(path: path, data: JSON.parse(File.read(file)), sha: file_sha(file))
      end
    end

    def verify_layout!(prefixes)
      prefixes.each do |prefix|
        directory = expanded_path(prefix)
        # Empty local roots are valid because writes create prefix directories on demand.
        next unless File.exist?(directory)
        next if Dir.exist?(directory)

        raise OperationalError, "state layout invalid: #{prefix} is not a directory"
      end
    end

    private

    def expanded_path(path)
      AgentCoord.safe_path!(path)
      expanded = File.expand_path(path, @root)
      raise Error, "state path escapes root: #{path}" unless expanded == @root || expanded.start_with?("#{@root}/")

      expanded
    end

    def with_file_lock(file)
      File.open("#{file}.lock", File::RDWR | File::CREAT, 0o600) do |lock|
        lock.flock(File::LOCK_EX)
        yield
      end
    end

    def file_sha(file)
      Digest::SHA256.file(file).hexdigest
    end
  end

  class GitHubStore
    def initialize(backend:, ref:)
      AgentCoord.validate_repo!(backend, "backend")
      @backend = backend
      @ref = ref
      @json_cache = {}
    end

    def read_json(path)
      AgentCoord.safe_path!(path)
      return @json_cache[path] if @json_cache.key?(path)

      result = gh_api("repos/#{@backend}/contents/#{path}?ref=#{@ref}")
      if result.not_found?
        verify_ref_readable!
        @json_cache[path] = nil
        return nil
      end
      raise OperationalError, result.error_message unless result.success?

      response = JSON.parse(result.stdout)
      content = Base64.decode64(response.fetch("content"))
      @json_cache[path] = StoredJson.new(path: path, data: JSON.parse(content), sha: response.fetch("sha"))
    end

    def write_json(path, data, message:, sha: nil, create: false)
      AgentCoord.safe_path!(path)
      args = [
        "-X", "PUT",
        "repos/#{@backend}/contents/#{path}",
        "-f", "message=#{message}",
        "-f", "branch=#{@ref}",
        "-f", "content=#{Base64.strict_encode64("#{JSON.pretty_generate(data)}\n")}"
      ]
      args.push("-f", "sha=#{sha}") if sha
      result = gh_api(*args)
      if result.conflict?
        invalidate_read_cache(path)
        reason = create ? "state already exists at #{path}" : "state changed at #{path}"
        raise Conflict, reason
      end
      raise OperationalError, result.error_message unless result.success?

      invalidate_read_cache(path)
    end

    def list_json(prefix)
      AgentCoord.safe_path!(prefix)
      tree_nodes.filter_map do |node|
        path = node["path"]
        next unless node["type"] == "blob" && path&.start_with?("#{prefix}/") && path.end_with?(".json")

        read_json(path)
      end
    end

    def verify_readable!
      tree_nodes
    end

    def verify_layout!(prefixes)
      nodes = tree_nodes
      prefixes.each do |prefix|
        next unless nodes.any? { |node| node["path"] == prefix && node["type"] != "tree" }

        raise OperationalError, "state layout invalid: #{prefix} is not a directory"
      end
    end

    private

    def verify_ref_readable!
      return if @ref_readable

      result = gh_api("repos/#{@backend}/git/trees/#{@ref}")
      unless result.success?
        raise OperationalError,
              "backend ref #{@backend}@#{@ref} is not readable: #{result.error_message}"
      end

      @ref_readable = true
    end

    def tree_nodes
      return @tree_nodes if defined?(@tree_nodes)

      result = gh_api("repos/#{@backend}/git/trees/#{@ref}?recursive=1")
      unless result.success?
        raise OperationalError,
              "backend ref #{@backend}@#{@ref} is not readable: #{result.error_message}"
      end

      @ref_readable = true
      @tree_nodes = JSON.parse(result.stdout).fetch("tree", [])
    end

    def invalidate_read_cache(path)
      @json_cache.delete(path)
      # Must remove the ivar so tree_nodes re-fetches after a successful write.
      remove_instance_variable(:@tree_nodes) if defined?(@tree_nodes)
    end

    def gh_api(*args)
      stdout, stderr, status = Open3.capture3("gh", "api", *args)
      GhResult.new(stdout: stdout, stderr: stderr, status: status)
    rescue SystemCallError => e
      raise OperationalError, "gh api #{args.join(' ')} failed: #{e.message}"
    end
  end

  class HttpStore
    OPEN_TIMEOUT = 5
    READ_TIMEOUT = 10
    LOOPBACK_HOSTS = %w[localhost 127.0.0.1 ::1].freeze
    PERCENT_ENCODE_UNSAFE = /[^A-Za-z0-9._~-]/
    RETRYABLE_REUSED_CONNECTION_ERRORS = [EOFError, Errno::ECONNRESET, Errno::EPIPE].freeze

    def initialize(base_url:, token:)
      uri = parse_base_url(base_url)
      @base = uri.to_s.chomp("/")
      @token = token
      @http = nil
      @list_filtered = {}
    end

    def read_json(path)
      AgentCoord.safe_path!(path)
      response = request(Net::HTTP::Get, state_path(path))
      if response.code == "404"
        body = parsed_json_object(response, "read #{path}")
        return nil if body["error"] == "not_found"

        raise OperationalError, http_error("read #{path}", response)
      end
      raise OperationalError, http_error("read #{path}", response) unless response.code == "200"

      body = parsed_json_object(response, "read #{path}")
      StoredJson.new(path: path, data: fetch_field(body, "data", "read #{path}"),
                     sha: fetch_field(body, "version", "read #{path}").to_s)
    end

    def list_json(prefix)
      AgentCoord.safe_path!(prefix)
      entries = []
      cursor = nil
      seen_cursors = {}
      @list_filtered[prefix] = false

      loop do
        response = request(Net::HTTP::Get, state_list_path(prefix, cursor))
        raise OperationalError, http_error("list #{prefix}", response) unless response.code == "200"

        body = parsed_json_object(response, "list #{prefix}")
        @list_filtered[prefix] = true if body["filtered"] == true
        entries.concat(parse_list_entries(body, prefix))
        cursor = next_list_cursor(body, prefix)
        break unless cursor

        if seen_cursors[cursor]
          message = "http backend list #{prefix} returned malformed response: repeated next_cursor"
          raise OperationalError, message
        end

        seen_cursors[cursor] = true
      end

      entries
    end

    def filtered_list?(prefix)
      @list_filtered.fetch(prefix, false)
    end

    # message is accepted for interface parity; the HTTP backend has no commit messages.
    def write_json(path, data, message:, sha: nil, create: false) # rubocop:disable Lint/UnusedMethodArgument
      AgentCoord.safe_path!(path)
      raise Error, "write_json requires sha or create" if sha.nil? && !create

      headers = sha ? { "If-Match" => sha } : { "If-None-Match" => "*" }
      response = request(Net::HTTP::Put, state_path(path), body: { "data" => data }, headers: headers)
      case response.code
      when "200", "201" then nil
      when "409"
        raise Conflict, (create ? "state already exists at #{path}" : "state changed at #{path}")
      else
        raise OperationalError, http_error("write #{path}", response)
      end
    end

    def verify_readable!(prefix = JSON_PREFIXES.first)
      AgentCoord.safe_path!(prefix)
      if AgentCoord.state_record_path?(prefix)
        read_json(prefix)
      else
        response = request(Net::HTTP::Get, "/v1/state?prefix=#{escape_component(prefix)}")
        raise OperationalError, http_error("verify readable", response) unless response.code == "200"
      end
    end

    def verify_layout!(_prefixes)
      response = request(Net::HTTP::Get, "/v1/health")
      raise OperationalError, http_error("health", response) unless response.code == "200"
    end

    def whoami
      response = request(Net::HTTP::Get, "/v1/whoami")
      return nil if response.code == "404"

      raise OperationalError, http_error("whoami", response) unless response.code == "200"

      body = parsed_json_object(response, "whoami")
      {
        "machine" => fetch_field(body, "machine", "whoami").to_s,
        "read_prefixes" => Array(fetch_field(body, "read_prefixes", "whoami")),
        "write_prefixes" => Array(fetch_field(body, "write_prefixes", "whoami"))
      }
    end

    def close
      close_http_session
    end

    private

    def parse_base_url(base_url)
      uri = URI.parse(base_url.to_s)
      unless %w[http https].include?(uri.scheme) && !uri.host.to_s.empty?
        raise OperationalError, "invalid HTTP backend URL: expected http(s) URL with host"
      end
      if uri.scheme == "http" && !LOOPBACK_HOSTS.include?(uri.host)
        raise OperationalError, "HTTP backend URL must use https unless it points at localhost"
      end

      uri
    rescue URI::InvalidURIError => e
      raise OperationalError, "invalid HTTP backend URL: #{e.message}"
    end

    def state_path(path)
      "/v1/state/#{escape_component(path)}"
    end

    def escape_component(value)
      URI::DEFAULT_PARSER.escape(value.to_s, PERCENT_ENCODE_UNSAFE)
    end

    def state_list_path(prefix, cursor)
      query = { "prefix" => prefix }
      query["cursor"] = cursor if cursor
      "/v1/state?#{URI.encode_www_form(query)}"
    end

    def parse_list_entries(body, prefix)
      entries = fetch_field(body, "entries", "list #{prefix}")
      unless entries.is_a?(Array)
        raise OperationalError, "http backend list #{prefix} returned malformed response: entries is not an array"
      end

      entries.map do |entry|
        unless entry.is_a?(Hash)
          raise OperationalError, "http backend list #{prefix} returned malformed response: entry is not an object"
        end

        StoredJson.new(path: fetch_field(entry, "path", "list #{prefix}"),
                       data: fetch_field(entry, "data", "list #{prefix}"),
                       sha: fetch_field(entry, "version", "list #{prefix}").to_s)
      end
    end

    def next_list_cursor(body, prefix)
      return nil unless body.key?("next_cursor") && !body["next_cursor"].nil?

      cursor = body["next_cursor"]
      unless cursor.is_a?(String)
        raise OperationalError, "http backend list #{prefix} returned malformed response: next_cursor is not a string"
      end
      return nil if cursor.empty?

      cursor
    end

    def parsed_json_object(response, action)
      body = JSON.parse(response.body)
      return body if body.is_a?(Hash)

      raise OperationalError, "http backend #{action} returned malformed response: expected object"
    rescue JSON::ParserError, TypeError => e
      raise OperationalError, "http backend #{action} returned malformed JSON: #{e.message}"
    end

    def fetch_field(body, field, action)
      body.fetch(field)
    rescue KeyError, NoMethodError
      raise OperationalError, "http backend #{action} returned malformed response: missing #{field}"
    end

    def request(klass, request_path, body: nil, headers: {})
      uri = URI.parse("#{@base}#{request_path}")
      attempts = 0

      begin
        http_session(uri).request(build_http_request(klass, uri, body, headers))
      rescue *RETRYABLE_REUSED_CONNECTION_ERRORS => e
        close_http_session
        attempts += 1
        retry if attempts == 1 && klass == Net::HTTP::Get

        raise e
      end
    rescue URI::InvalidURIError, SocketError, SystemCallError, Timeout::Error, IOError, OpenSSL::SSL::SSLError => e
      close_http_session
      raise OperationalError, "http backend unreachable: #{e.message}"
    end

    def build_http_request(klass, uri, body, headers)
      http_request = klass.new(uri)
      http_request["Authorization"] = "Bearer #{@token}"
      headers.each { |name, value| http_request[name] = value }
      if body
        http_request["Content-Type"] = "application/json"
        http_request.body = JSON.generate(body)
      end
      http_request
    end

    def http_session(uri)
      return @http if @http&.active?

      close_http_session
      @http = Net::HTTP.start(
        uri.host,
        uri.port,
        use_ssl: uri.scheme == "https",
        open_timeout: OPEN_TIMEOUT,
        read_timeout: READ_TIMEOUT
      )
      @http.max_retries = 0 if @http.respond_to?(:max_retries=)
      @http
    end

    def close_http_session
      @http&.finish if @http&.active?
    rescue StandardError
      nil
    ensure
      @http = nil
    end

    def http_error(action, response)
      detail = begin
        parsed = JSON.parse(response.body)
        parsed.is_a?(Hash) ? parsed.fetch("error", response.body) : response.body.to_s[0, 200]
      rescue JSON::ParserError, TypeError
        response.body.to_s[0, 200]
      end
      "http backend #{action} failed: #{response.code} #{detail}"
    end
  end

  GhResult = Struct.new(:stdout, :stderr, :status, keyword_init: true) do
    def success?
      status.success?
    end

    def not_found?
      !success? && error_message.match?(/404|not found/i)
    end

    def conflict?
      !success? && error_message.match?(/409|422|sha|already exists|conflict/i)
    end

    def error_message
      [stderr, stdout].reject(&:empty?).join("\n")
    end
  end

  def self.safe_path!(path)
    return unless path.to_s.empty? || path.include?("..") || path.start_with?("/") || path.split("/").any?(&:empty?)

    raise PathValidationError, "unsafe state path: #{path}"
  end

  def self.state_record_path?(path)
    path.to_s.match?(STATE_PATH_PATTERN)
  end

  def self.validate_repo!(repo, field)
    value = repo.to_s
    return if value.match?(%r{\A[A-Za-z0-9_.-]+/[A-Za-z0-9_.-]+\z})

    raise Error, "invalid #{field} repo: #{repo}"
  end

  def self.validate_segment!(segment, field)
    return if segment.to_s.match?(/\A[A-Za-z0-9_:-]+(?:\.[A-Za-z0-9_:-]+)*\z/)

    raise PathValidationError, "invalid #{field}: #{segment}"
  end

  def self.claim_path(repo, target)
    validate_repo!(repo, "target")
    validate_segment!(target, "target")
    "claims/#{repo}/#{target}.json"
  end

  def self.heartbeat_path(agent_id)
    validate_segment!(agent_id, "agent-id")
    "heartbeats/#{agent_id}.json"
  end

  def self.batch_path(batch_id)
    validate_segment!(batch_id, "batch-id")
    "batches/#{batch_id}.json"
  end

  def self.event_path(batch_id, event_id)
    validate_segment!(batch_id, "batch-id")
    validate_segment!(event_id, "event-id")
    "events/#{batch_id}/#{event_id}.json"
  end

  def self.event_batch_prefix(batch_id)
    validate_segment!(batch_id, "batch-id")
    "events/#{batch_id}"
  end

  def self.event_batch_from_path(path)
    parts = path.split("/")
    parts.length >= 3 ? parts[1] : "UNKNOWN"
  end

  def self.repo_from_claim_path(path)
    parts = path.split("/")
    return "UNKNOWN" unless parts.length >= 4

    "#{parts[1]}/#{parts[2]}"
  end

  def self.target_from_path(path)
    File.basename(path, ".json")
  end

  def self.source_root
    File.expand_path("..", __dir__)
  end

  def self.state_root?(root)
    JSON_PREFIXES.all? { |prefix| Dir.exist?(File.join(root, prefix)) }
  end
end

# RubyGems-generated wrappers load the same-named executable, so basename equality is intentional.
if File.basename($PROGRAM_NAME) == File.basename(__FILE__)
  begin
    exit AgentCoord::Runner.new(ARGV).run
  rescue AgentCoord::Error => e
    warn e.message
    exit e.exit_code
  end
end
