#!/usr/bin/env bash
set -euo pipefail
cd "$(dirname "$0")/.."
TMP_ROOT=$(mktemp -d "${TMPDIR:-/tmp}/agent-coord-wrangler.XXXXXX")
WRANGLER_STATE_DIR="$TMP_ROOT/state"
WRANGLER_PID=""
set -m 2>/dev/null || true

process_alive() {
  local pid="$1"
  kill -0 "$pid" 2>/dev/null
}

process_group_alive() {
  local pid="$1"
  kill -0 "-$pid" 2>/dev/null
}

collect_tree() {
  local pid="$1"
  local child
  process_alive "$pid" || return 0
  if command -v pgrep >/dev/null 2>&1; then
    for child in $(pgrep -P "$pid" 2>/dev/null || true); do
      collect_tree "$child"
    done
  fi
  printf '%s\n' "$pid"
}

signal_pids() {
  local signal="$1"
  local pid
  while IFS= read -r pid; do
    [ -n "$pid" ] || continue
    kill "$signal" "$pid" 2>/dev/null || true
  done
}

signal_wrangler() {
  local signal="$1"
  kill "$signal" "-$WRANGLER_PID" 2>/dev/null || signal_pids "$signal" <<<"$(collect_tree "$WRANGLER_PID")"
}

wait_for_wrangler_exit() {
  local deadline=$((SECONDS + 5))
  while [ "$SECONDS" -lt "$deadline" ]; do
    if ! process_group_alive "$WRANGLER_PID" && [ -z "$(collect_tree "$WRANGLER_PID")" ]; then
      return 0
    fi
    sleep 0.2
  done
  return 1
}

cleanup() {
  local status=$?
  if [ -n "$WRANGLER_PID" ]; then
    signal_wrangler -TERM
    if ! wait_for_wrangler_exit; then
      signal_wrangler -KILL
    fi
    wait "$WRANGLER_PID" 2>/dev/null || true
  fi
  ruby -rfileutils -e 'FileUtils.rm_rf(ARGV.fetch(0))' "$TMP_ROOT"
  return "$status"
}
trap cleanup EXIT
trap 'exit 130' INT TERM

export XDG_CONFIG_HOME="$TMP_ROOT/config"
export XDG_CACHE_HOME="$TMP_ROOT/cache"
export WRANGLER_LOG_PATH="$TMP_ROOT/logs"
export WRANGLER_OUTPUT_LOG="$TMP_ROOT/wrangler-integration.log"
export WRANGLER_SEND_METRICS=false
export WRANGLER_SEND_ERROR_REPORTS=false
mkdir -p "$XDG_CONFIG_HOME" "$XDG_CACHE_HOME" "$WRANGLER_LOG_PATH"
TOKEN=$(ruby -rsecurerandom -e 'print SecureRandom.hex(24)')
HASH=$(ruby -rdigest -e 'print Digest::SHA256.hexdigest(ARGV.fetch(0))' "$TOKEN")
SCOPED_TOKEN=$(ruby -rsecurerandom -e 'print SecureRandom.hex(24)')
SCOPED_HASH=$(ruby -rdigest -e 'print Digest::SHA256.hexdigest(ARGV.fetch(0))' "$SCOPED_TOKEN")
ARCHIVE_TOKEN=$(ruby -rsecurerandom -e 'print SecureRandom.hex(24)')
ARCHIVE_HASH=$(ruby -rdigest -e 'print Digest::SHA256.hexdigest(ARGV.fetch(0))' "$ARCHIVE_TOKEN")
MIRRORED_TOKEN=$(ruby -rsecurerandom -e 'print SecureRandom.hex(24)')
MIRRORED_HASH=$(ruby -rdigest -e 'print Digest::SHA256.hexdigest(ARGV.fetch(0))' "$MIRRORED_TOKEN")
SCOPED_CLAIM_PREFIX="claims/shakacode/api.json"
SCOPED_SECONDARY_CLAIM_PREFIX="claims/shakacode/scoped-secondary"
MIRRORED_CLAIM_PREFIX="claims/shakacode/mirrored-delete"

health_ready() {
  ruby -rnet/http -ruri -e '
    uri = URI("http://127.0.0.1:8787/v1/health")
    response = Net::HTTP.start(uri.host, uri.port, open_timeout: 1, read_timeout: 1) do |http|
      http.get(uri.request_uri)
    end
    exit(response.is_a?(Net::HTTPSuccess) ? 0 : 1)
  ' >/dev/null 2>&1
}

(cd worker && npx wrangler d1 migrations apply agent-coord --local --persist-to "$WRANGLER_STATE_DIR" >/dev/null)
(cd worker && npx wrangler d1 execute agent-coord --local --command \
  "INSERT OR REPLACE INTO machines (machine, token_hash, created_at) VALUES ('integration', '${HASH}', '2026-07-04T00:00:00Z')" \
  --persist-to "$WRANGLER_STATE_DIR" >/dev/null)
(cd worker && npx wrangler d1 execute agent-coord --local --command \
  "INSERT OR REPLACE INTO machines (machine, token_hash, read_prefixes, write_prefixes, created_at) VALUES ('scoped', '${SCOPED_HASH}', '[\"${SCOPED_CLAIM_PREFIX}\",\"${SCOPED_SECONDARY_CLAIM_PREFIX}\"]', '[\"${SCOPED_CLAIM_PREFIX}\"]', '2026-07-04T00:00:00Z')" \
  --persist-to "$WRANGLER_STATE_DIR" >/dev/null)
(cd worker && npx wrangler d1 execute agent-coord --local --command \
  "INSERT OR REPLACE INTO machines (machine, token_hash, read_prefixes, write_prefixes, created_at) VALUES ('archive-only', '${ARCHIVE_HASH}', '[\"archive\"]', '[\"archive\"]', '2026-07-04T00:00:00Z')" \
  --persist-to "$WRANGLER_STATE_DIR" >/dev/null)
(cd worker && npx wrangler d1 execute agent-coord --local --command \
  "INSERT OR REPLACE INTO machines (machine, token_hash, read_prefixes, write_prefixes, created_at) VALUES ('mirrored', '${MIRRORED_HASH}', '[\"${MIRRORED_CLAIM_PREFIX}\",\"archive/${MIRRORED_CLAIM_PREFIX}\"]', '[\"${MIRRORED_CLAIM_PREFIX}\",\"archive/${MIRRORED_CLAIM_PREFIX}\"]', '2026-07-04T00:00:00Z')" \
  --persist-to "$WRANGLER_STATE_DIR" >/dev/null)
(cd worker && npx wrangler dev --local --persist-to "$WRANGLER_STATE_DIR" --port 8787 >"$WRANGLER_OUTPUT_LOG" 2>&1) &
WRANGLER_PID=$!
set +m 2>/dev/null || true
for _ in $(seq 1 60); do
  process_alive "$WRANGLER_PID" || { echo "wrangler dev exited before becoming healthy"; cat "$WRANGLER_OUTPUT_LOG"; exit 1; }
  health_ready && break
  sleep 0.5
done
process_alive "$WRANGLER_PID" || { echo "wrangler dev exited before becoming healthy"; cat "$WRANGLER_OUTPUT_LOG"; exit 1; }
health_ready || { echo "wrangler dev never became healthy"; cat "$WRANGLER_OUTPUT_LOG"; exit 1; }
AGENT_COORD_API_URL=http://127.0.0.1:8787 \
  AGENT_COORD_API_TOKEN="$TOKEN" \
  SCOPED_AGENT_COORD_API_TOKEN="$SCOPED_TOKEN" \
  ARCHIVE_AGENT_COORD_API_TOKEN="$ARCHIVE_TOKEN" \
  MIRRORED_AGENT_COORD_API_TOKEN="$MIRRORED_TOKEN" \
  MIRRORED_CLAIM_PREFIX="$MIRRORED_CLAIM_PREFIX" \
  SCOPED_CLAIM_PREFIX="$SCOPED_CLAIM_PREFIX" \
  SCOPED_SECONDARY_CLAIM_PREFIX="$SCOPED_SECONDARY_CLAIM_PREFIX" \
  bundle exec ruby test/http_backend_integration_test.rb
echo INTEGRATION_OK
